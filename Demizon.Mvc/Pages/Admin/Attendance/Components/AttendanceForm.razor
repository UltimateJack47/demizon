@using Demizon.Mvc.ViewModels
<MudDialog>
    <DialogContent>
        @if (Model.Event is not null)
        {
            <MudText Align="Align.Center" Typo="Typo.h4">
                @(Model.Event.Name + " ")
                @if (Model.Event.DateFrom == Model.Event.DateTo)
                {
                    @(Model.Event.DateFrom.ToString("dd.MM."))
                }
                else
                {
                    @(Model.Event.DateFrom.ToString("dd.MM.") + " - " + Model.Event.DateTo.ToString("dd.MM."))
                }

            </MudText>
        }
        else
        {
            @Model.Date.ToString("dd.MM.")
        }
        <MudCheckBox @bind-Value="Model.Attends" Label="Zúčastním se"/>
        <MudTextField @bind-Value="Model.Comment" Label="Poznámka"/>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        @if (Model.Id != 0)
        {
            <MudButton Color="Color.Warning" OnClick="ClickedReset">Resetovat</MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">
            <span>Potvrdit</span>
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public AttendanceViewModel Model { get; set; } = new();

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void ClickedOk()
    {
        MudDialog.Close(DialogResult.Ok(Model));
    }

    private void ClickedReset()
    {
        MudDialog.Close(DialogResult.Ok<AttendanceViewModel?>(null));
    }

}
