@using Demizon.Mvc.ViewModels
@using Demizon.Dal.Entities
<MudDialog Style="min-width: min(360px, calc(100vw - 32px))">
    <TitleContent>
        @if (Model.Event is not null)
        {
            <MudStack Spacing="0">
                <MudText Typo="Typo.h6">@Model.Event.Name</MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    @(Model.Event.DateFrom.Date == Model.Event.DateTo.Date
                        ? Model.Event.DateFrom.ToString("d. M. yyyy")
                        : $"{Model.Event.DateFrom:d. M.} – {Model.Event.DateTo:d. M. yyyy}")
                </MudText>
            </MudStack>
        }
        else
        {
            <MudText Typo="Typo.h6">Zkouška @Model.Date.ToString("d. M. yyyy")</MudText>
        }
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudCheckBox @bind-Value="Model.Attends" Label="Zúčastním se" Color="Color.Primary"/>
            </MudItem>
            @if (Model.Member.IsDancer && Model.Member.IsMusician)
            {
                <MudItem xs="12">
                    <MudSelect T="AttendanceActivityRole?" @bind-Value="Model.ActivityRole"
                               Label="Role na akci" Clearable="true" Variant="Variant.Outlined"
                               Margin="Margin.Dense" HelperText="Nevyplněno = muzikant (výchozí)">
                        <MudSelectItem T="AttendanceActivityRole?" Value="AttendanceActivityRole.Dancer">Tanečník/Tanečnice</MudSelectItem>
                        <MudSelectItem T="AttendanceActivityRole?" Value="AttendanceActivityRole.Musician">Muzikant</MudSelectItem>
                    </MudSelect>
                </MudItem>
            }
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Comment" Label="Poznámka"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        @if (Model.Id != 0)
        {
            <MudButton Color="Color.Warning" OnClick="ClickedReset">Resetovat</MudButton>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">Potvrdit</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public AttendanceViewModel Model { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();
    private void ClickedOk() => MudDialog.Close(DialogResult.Ok(Model));
    private void ClickedReset() => MudDialog.Close(DialogResult.Ok<AttendanceViewModel?>(null));
}
