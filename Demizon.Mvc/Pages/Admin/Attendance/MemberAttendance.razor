@page "/Admin/MemberAttendance/"
@using Demizon.Dal.Entities

@attribute [Authorize(Roles = "Admin, Standard")]

<PageTitle>@PageService.GetTitle()</PageTitle>

@layout AdminMainLayout

<!-- ─── Měsíční navigace ─── -->
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Color="Color.Primary"
                   OnClick="PreviousMonth" Size="Size.Large" title="Předchozí měsíc"/>
    <MudText Typo="Typo.h5" Style="text-transform: capitalize; min-width: 180px; text-align: center;">
        @MonthLabel
    </MudText>
    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="Color.Primary"
                   OnClick="NextMonth" Size="Size.Large" title="Následující měsíc"/>
</MudStack>

<!-- ─── Filtr ─── -->
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Class="mb-2" Wrap="Wrap.Wrap">
    <MudSelect T="Gender?" @bind-Value="GenderFilter" Label="Pohlaví" Style="max-width: 160px;"
               Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense">
        <MudSelectItem T="Gender?" Value="null">Vše</MudSelectItem>
        <MudSelectItem T="Gender?" Value="Gender.Female">Ženy</MudSelectItem>
        <MudSelectItem T="Gender?" Value="Gender.Male">Muži</MudSelectItem>
    </MudSelect>
    <MudCheckBox @bind-Value="ShowAttendanceHidden" Label="Zobrazit skryté v docházce" Color="Color.Secondary" Class="mr-3"/>
</MudStack>

<!-- ─── Tabulka docházky ─── -->
<div class="demi-att-table-wrap">
    <table class="demi-att-table">
        <thead>
            <tr>
                <th class="demi-att-sticky">Člen</th>
                @foreach (var col in Attendances)
                {
                    <th class="demi-att-col-header @(col.Event?.IsCancelled == true ? "demi-att-col-cancelled" : "")">
                        @if (col.Event is not null)
                        {
                            <span class="demi-att-event-label">
                                @col.Event.Name
                                @if (col.Event.IsCancelled)
                                {
                                    <span style="font-size:0.6rem; margin-left:2px; opacity:0.7;">(zrušena)</span>
                                }
                            </span><br/>
                            <span class="demi-att-date-label">
                                @(col.Event.DateFrom.Date == col.Event.DateTo.Date
                                    ? col.Event.DateFrom.ToString("d.M.")
                                    : $"{col.Event.DateFrom:d.M.}–{col.Event.DateTo:d.M.}")
                            </span>
                        }
                        else
                        {
                            <span class="demi-att-date-label">@col.Date.ToString("d.M.")</span><br/>
                            <span style="font-size: 0.6rem; color: #aaa;">@FormatDayAbbr(col.Date)</span>
                        }
                    </th>
                }
            </tr>
        </thead>
        <tbody>
            <!-- Ženy -->
            @if (GenderFilter == null || GenderFilter == Gender.Female)
            {
                @foreach (var member in FilteredFemales)
                {
                    <tr class="@(!member.IsAttendanceVisible ? "demi-att-row-hidden" : "")">
                        <td class="demi-att-sticky demi-att-name">
                            @member.Name @member.Surname
                            @if (!member.IsAttendanceVisible)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small"
                                         Style="opacity:0.4; vertical-align: middle; margin-left: 4px;"/>
                            }
                        </td>
                        @foreach (var col in Attendances)
                        {
                            <td class="@(col.Event?.IsCancelled == true ? "demi-att-cell demi-att-cell-cancelled" : "demi-att-cell") @(!member.IsAttendanceVisible ? "demi-att-cell-readonly" : "")"
                                @onclick="@(async () => { if (col.Event?.IsCancelled != true && member.IsAttendanceVisible) await SetAttendanceMember(member, col); })">
                                @{
                                    var day = member.Attendances.FirstOrDefault(x => x.Date == col.Date);
                                }
                                @if (day is not null)
                                {
                                    <MudIcon Icon="@(day.Attends ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                             Color="@(day.Attends ? Color.Success : Color.Error)"
                                             Size="Size.Small"/>
                                }
                            </td>
                        }
                    </tr>
                }
                <tr class="demi-att-sum-row">
                    <td class="demi-att-sticky"><b>Σ ženy</b></td>
                    @foreach (var col in Attendances)
                    {
                        <td><b>@CountAttending(FilteredFemales, col.Date)</b></td>
                    }
                </tr>
                <tr class="demi-att-activity-row demi-att-dancer-row">
                    <td class="demi-att-sticky"><b>Σ tanečnice</b></td>
                    @foreach (var col in Attendances)
                    {
                        <td>@CountAttendingFemaleDancers(col.Date)</td>
                    }
                </tr>
            }

            <!-- Muži -->
            @if (GenderFilter == null || GenderFilter == Gender.Male)
            {
                @foreach (var member in FilteredMales)
                {
                    <tr class="@(!member.IsAttendanceVisible ? "demi-att-row-hidden" : "")">
                        <td class="demi-att-sticky demi-att-name">
                            @member.Name @member.Surname
                            @if (!member.IsAttendanceVisible)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small"
                                         Style="opacity:0.4; vertical-align: middle; margin-left: 4px;"/>
                            }
                        </td>
                        @foreach (var col in Attendances)
                        {
                            <td class="@(col.Event?.IsCancelled == true ? "demi-att-cell demi-att-cell-cancelled" : "demi-att-cell") @(!member.IsAttendanceVisible ? "demi-att-cell-readonly" : "")"
                                @onclick="@(async () => { if (col.Event?.IsCancelled != true && member.IsAttendanceVisible) await SetAttendanceMember(member, col); })">
                                @{
                                    var day = member.Attendances.FirstOrDefault(x => x.Date == col.Date);
                                }
                                @if (day is not null)
                                {
                                    <MudIcon Icon="@(day.Attends ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                             Color="@(day.Attends ? Color.Success : Color.Error)"
                                             Size="Size.Small"/>
                                }
                            </td>
                        }
                    </tr>
                }
                <tr class="demi-att-sum-row">
                    <td class="demi-att-sticky"><b>Σ muži</b></td>
                    @foreach (var col in Attendances)
                    {
                        <td><b>@CountAttending(FilteredMales, col.Date)</b></td>
                    }
                </tr>
                <tr class="demi-att-activity-row demi-att-dancer-row">
                    <td class="demi-att-sticky"><b>Σ tanečníci</b></td>
                    @foreach (var col in Attendances)
                    {
                        <td>@CountAttendingMaleDancers(col.Date)</td>
                    }
                </tr>
            }
            
            <!-- Externisté -->
            @if (FilteredExternals.Any())
            {
                <tr>
                    <td class="demi-att-sticky" colspan="@(Attendances.Count + 1)"
                        style="background: var(--mud-palette-warning-lighten); font-size:0.75rem; padding: 2px 8px;">
                        Externisté
                    </td>
                </tr>
                @foreach (var member in FilteredExternals)
                {
                    <tr class="@(!member.IsAttendanceVisible ? "demi-att-row-hidden" : "")">
                        <td class="demi-att-sticky demi-att-name">
                            @member.Name @member.Surname
                            <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Text"
                                     Style="font-size:0.6rem; height:16px; padding: 0 4px;">ext</MudChip>
                            @if (!member.IsAttendanceVisible)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Size="Size.Small"
                                         Style="opacity:0.4; vertical-align: middle; margin-left: 4px;"/>
                            }
                        </td>
                        @foreach (var col in Attendances)
                        {
                            <td class="@(col.Event?.IsCancelled == true ? "demi-att-cell demi-att-cell-cancelled" : "demi-att-cell") @(!member.IsAttendanceVisible ? "demi-att-cell-readonly" : "")"
                                @onclick="@(async () => { if (col.Event?.IsCancelled != true && member.IsAttendanceVisible) await SetAttendanceMember(member, col); })">
                                @{
                                    var extDay = member.Attendances.FirstOrDefault(x => x.Date == col.Date);
                                }
                                @if (extDay is not null)
                                {
                                    <MudIcon Icon="@(extDay.Attends ? Icons.Material.Filled.Check : Icons.Material.Filled.Close)"
                                             Color="@(extDay.Attends ? Color.Success : Color.Error)"
                                             Size="Size.Small"/>
                                }
                            </td>
                        }
                    </tr>
                }
                <tr class="demi-att-sum-row">
                    <td class="demi-att-sticky"><b>Σ externisté</b></td>
                    @foreach (var col in Attendances)
                    {
                        <td><b>@CountAttending(FilteredExternals, col.Date)</b></td>
                    }
                </tr>
            }

            <!-- Σ muzikanti (vždy, nezávisle na pohlavním filtru) -->
            <tr class="demi-att-activity-row demi-att-musician-row">
                <td class="demi-att-sticky"><b>Σ muzikanti</b></td>
                @foreach (var col in Attendances)
                {
                    <td>@CountAttendingMusicians(col.Date)</td>
                }
            </tr>

            <!-- Celkový součet -->
            @if (GenderFilter == null)
            {
                <tr class="demi-att-total-row">
                    <td class="demi-att-sticky"><b>Σ celkem</b></td>
                    @foreach (var col in Attendances)
                    {
                        <td><b>@CountAttending(FilteredFemales.Concat(FilteredMales).Concat(FilteredExternals), col.Date)</b></td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>
