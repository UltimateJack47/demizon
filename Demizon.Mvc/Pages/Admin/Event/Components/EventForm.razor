@using Demizon.Mvc.ViewModels
<MudDialog Style="min-width: min(520px, calc(100vw - 32px))">
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsUpdate ? "Upravit" : "Vytvořit") - Akce</MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudTextField @bind-Value="EventModel.Name" Label="Název"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Required="true" RequiredError="Název je povinný!"/>
            </MudItem>
            <MudItem xs="12">
                <MudDateRangePicker @bind-DateRange="EventModel.Date" Label="Kdy"
                                    Variant="Variant.Outlined" Margin="Margin.Dense" Editable="true"/>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="EventModel.Place" Label="Místo"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="EventModel.Information" Label="Informace"
                              Variant="Variant.Outlined" Margin="Margin.Dense" Lines="3"/>
            </MudItem>
            <MudItem xs="12">
                <MudDivider Class="my-1"/>
                <MudGrid Spacing="0">
                    <MudItem xs="12" sm="6">
                        <MudCheckBox @bind-Value="EventModel.IsPublic" Label="Veřejné" Color="Color.Primary"/>
                    </MudItem>
                </MudGrid>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">
            @(IsUpdate ? "Uložit" : "Vytvořit")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public EventViewModel EventModel { get; set; } = new();
    [Parameter] public bool IsUpdate { get; set; }

    private void Cancel() => MudDialog.Cancel();
    private void ClickedOk() => MudDialog.Close(DialogResult.Ok(EventModel));
}
