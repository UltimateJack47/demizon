@page "/Admin/Events"
@using Demizon.Core.Services.Event
@using Demizon.Mvc.Pages.Admin.Event.Components
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

@layout AdminMainLayout

<PageTitle>Události</PageTitle>

@inject IEventService EventService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "Admin, Standard")]

<MudTable @ref="EventsGrid" T="EventViewModel" Items="Events" Hover="true" Striped="true" FixedHeader="true" Height="900px"
          RowClassFunc="@((item, _) => item.IsCancelled ? "demi-event-row-cancelled" : "")">
    <ToolBarContent>
        <MudText Typo="Typo.h3">Události</MudText>
        <MudSpacer/>
        <MudIconButton Class="mt-0" Size="Size.Medium" aria-label="refresh" OnClick="RefreshTable" Icon="@Icons.Material.Filled.Refresh"/>
        <AuthorizeView Roles="Admin">
            <MudButton Size="Size.Medium" Variant="Variant.Filled" ButtonType="ButtonType.Button" Color="Color.Primary"
                       @onclick="() => OpenFormDialog()">
                Vytvořit
            </MudButton>
        </AuthorizeView>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><b>Název</b></MudTh>
        <MudTh><b>Datum</b></MudTh>
        <MudTh><b>Místo</b></MudTh>
        <MudTh Style="width: 40px"></MudTh>
        <MudTh Style="width: 80px"></MudTh>
    </HeaderContent>
    <RowTemplate Context="upcomingEvent">
        <MudTd>@upcomingEvent.Name</MudTd>
        <MudTd>
            @if (upcomingEvent.DateFrom.Date != upcomingEvent.DateTo.Date)
            {
                @($"{upcomingEvent.DateFrom:d. MMMM yyyy} – {upcomingEvent.DateTo:d. MMMM yyyy}")
            }
            else
            {
                @upcomingEvent.DateFrom.ToString("d. MMMM yyyy")
            }
        </MudTd>
        <MudTd>@upcomingEvent.Place</MudTd>
        <MudTd>
            @if (upcomingEvent.IsPublic)
            {
                <MudIcon Icon="@Icons.Material.Filled.Visibility" Color="Color.Success"/>
            }
            else
            {
                <MudIcon Icon="@Icons.Material.Filled.VisibilityOff" Color="Color.Error"/>
            }
            @if (upcomingEvent.IsCancelled)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Icon="@Icons.Material.Filled.Cancel" Class="ml-1">Zrušena</MudChip>
            }
        </MudTd>
        <MudTd>
            <AuthorizeView Roles="Admin">
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="() => OpenFormDialog(upcomingEvent)"/>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" OnClick="() => RemoveEvent(upcomingEvent.Id)"/>
                @if (!upcomingEvent.IsCancelled)
                {
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.EventBusy"
                                   Color="Color.Error" title="Označit jako zrušenou"
                                   OnClick="() => CancelEvent(upcomingEvent.Id, true)"/>
                }
                else
                {
                    <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.EventAvailable"
                                   Color="Color.Success" title="Reaktivovat událost"
                                   OnClick="() => CancelEvent(upcomingEvent.Id, false)"/>
                }
            </AuthorizeView>
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    private List<EventViewModel> Events { get; set; } = new();

    private MudTable<EventViewModel> EventsGrid { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        Events = (await EventService.GetAll().ToListAsync()).Select(x => x.ToViewModel()).ToList();
    }

    private async Task RefreshTable()
    {
        Events = (await EventService.GetAll().OrderByDescending(x => x.DateFrom).ToListAsync()).Select(x => x.ToViewModel()).ToList();
        StateHasChanged();
    }

    private async Task OpenFormDialog(EventViewModel? viewModel = null)
    {
        var isUpdate = viewModel is not null;
        var options = new DialogOptions {CloseOnEscapeKey = true};
        var parameters = new DialogParameters
        {
            {"IsUpdate", isUpdate},
            {"EventModel", viewModel ?? new EventViewModel()}
        };
        var dialog = await DialogService.ShowAsync<EventForm>("Event form", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            var memberResult = result.Data as EventViewModel;
            try
            {
                if (isUpdate)
                {
                    await EventService.UpdateAsync(viewModel!.Id, memberResult!.ToEntity());
                    Snackbar.Add("Událost byla upravena.", Severity.Success);
                }
                else
                {
                    await EventService.CreateAsync(memberResult!.ToEntity());
                    Snackbar.Add("Událost byla vytvořena.", Severity.Success);
                }

                await RefreshTable();
            }
            catch (Exception)
            {
                Snackbar.Add("Něco se pokazilo.", Severity.Error);
            }
        }
    }

    private void NavigateToDetail(int id)
    {
        NavigationManager.NavigateTo(NavigationManager.BaseUri + $"Events/Detail/{id}");
    }

    private async Task RemoveEvent(int id)
    {
        var result = await DialogService.ShowMessageBoxAsync("Smazat položku?", "", "Ano", "Zrušit");
        if (result.HasValue && result.Value)
        {
            await EventService.DeleteAsync(id);
            Events.RemoveAll(x => x.Id == id);
        }
    }

    private async Task CancelEvent(int id, bool isCancelled)
    {
        var action = isCancelled ? "zrušit" : "reaktivovat";
        var result = await DialogService.ShowMessageBoxAsync($"Chcete {action} tuto událost?", "", "Ano", "Zrušit");
        if (result.HasValue && result.Value)
        {
            try
            {
                await EventService.SetCancelledAsync(id, isCancelled);
                Snackbar.Add(isCancelled ? "Událost byla zrušena." : "Událost byla reaktivována.", Severity.Success);
                await RefreshTable();
            }
            catch (Exception)
            {
                Snackbar.Add("Něco se pokazilo.", Severity.Error);
            }
        }
    }

}
