@using Demizon.Mvc.ViewModels
<MudDialog Style="min-width: min(460px, calc(100vw - 32px))">
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsUpdate ? "Upravit" : "Vytvořit") - Tanec</MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Name" Label="Název"
                              Required="true" RequiredError="Název je povinný!"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Region" Label="Region (Slovácko, Haná, Valašsko…)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Description" Label="Popis tance" Lines="3"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="Model.Lyrics" Label="Texty písní" Lines="5"
                              HelperText="Texty písní zpívaných při tanci (nepovinné)"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12">
                <MudDivider Class="my-1"/>
                <MudCheckBox @bind-Value="Model.IsVisible" Label="Veřejné" Color="Color.Primary"/>
            </MudItem>
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">
            @(IsUpdate ? "Uložit" : "Vytvořit")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public DanceViewModel Model { get; set; } = new();
    [Parameter] public bool IsUpdate { get; set; }

    private void Cancel() => MudDialog.Cancel();
    private void ClickedOk() => MudDialog.Close(DialogResult.Ok(Model));
}
