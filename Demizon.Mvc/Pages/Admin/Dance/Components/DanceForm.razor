@using Demizon.Mvc.ViewModels
<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@Localizer[nameof(DemizonLocales.Dance)] - @Localizer[nameof(DemizonLocales.Form)]</MudText>
    </TitleContent>

    <DialogContent>
        <MudTextField @bind-Value="Model.Name" Label="@Localizer[nameof(DemizonLocales.Name)]" Required="true" RequiredError="Name is required!" Class="mb-2"/>
        <MudTextField @bind-Value="Model.Region" Label="Region (Slovácko, Haná, Valašsko…)" Class="mb-2"/>
        <MudTextField @bind-Value="Model.Description" Label="Popis tance" Lines="3" Class="mb-2"/>
        <MudCheckBox @bind-Value="Model.IsVisible" Label="@Localizer[nameof(DemizonLocales.IsVisible)]"/>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">@Localizer[nameof(DemizonLocales.Cancel)]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">
            @if (IsUpdate)
            {
                <span>@Localizer[nameof(DemizonLocales.Update)]</span>
            }
            else
            {
                <span>@Localizer[nameof(DemizonLocales.Create)]</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = null!;
    
    [Parameter]
    public DanceViewModel Model { get; set; } = new ();
    
    [Parameter]
    public bool IsUpdate { get; set; }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void ClickedOk()
    {
        MudDialog.Close(DialogResult.Ok(Model));
    }
}
