@using Demizon.Mvc.ViewModels

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsUpdate ? "Upravit" : "Přidat") číslo tance
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudTextField @bind-Value="Model.Title" Label="Název čísla" Required="true"
                      RequiredError="Název je povinný!" Class="mb-2"/>
        <MudTextField @bind-Value="Model.Description" Label="Popis (nepovinný)" Lines="3" Class="mb-2"/>
        <MudTextField @bind-Value="Model.Lyrics" Label="Texty písní (nepovinné)" Lines="6"
                      HelperText="Texty písní, které se zpívají při tomto čísle"/>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">
            @(IsUpdate ? "Uložit" : "Přidat")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public DanceNumberViewModel Model { get; set; } = new();
    [Parameter] public bool IsUpdate { get; set; }

    private void Cancel() => MudDialog.Cancel();
    private void ClickedOk() => MudDialog.Close(DialogResult.Ok(Model));
}
