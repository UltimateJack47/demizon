@page "/Admin"
@page "/Admin/Dances"
@using Demizon.Core.Services.Dance
@using Demizon.Dal.Entities
@using Demizon.Mvc.Pages.Admin.Dance.Components
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

<PageTitle>Tance</PageTitle>
@inject IDanceService DanceService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "Admin, Standard")]

@layout AdminMainLayout

<MudTable @ref="DancesGrid" T="DanceViewModel" Items="Dances" Hover="true" Striped="true" FixedHeader="true" Height="900px">
    <ToolBarContent>
        <MudText Typo="Typo.h3">Tance</MudText>
        <MudSpacer/>
        <MudIconButton Class="mt-0" Size="Size.Medium" aria-label="refresh" OnClick="RefreshTable" Icon="@Icons.Material.Filled.Refresh"/>
        <AuthorizeView Roles="Admin">
            <MudButton Size="Size.Medium" Variant="Variant.Filled" ButtonType="ButtonType.Button" Color="Color.Primary"
                       @onclick="() => OpenFormDialog()">
                Vytvořit
            </MudButton>
        </AuthorizeView>
    </ToolBarContent>
    <HeaderContent>
        <MudTh><b>Název</b></MudTh>
        <MudTh><b>Region</b></MudTh>
        <MudTh><b>Veřejné?</b></MudTh>
        <MudTh Style="width: 120px"></MudTh>
    </HeaderContent>
    <RowTemplate Context="dance">
        <MudTd>@dance.Name</MudTd>
        <MudTd>
            @if (!string.IsNullOrWhiteSpace(dance.Region))
            {
                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">@dance.Region</MudChip>
            }
        </MudTd>
        <MudTd>
            <MudIcon Icon="@(dance.IsVisible ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                     Color="@(dance.IsVisible ? Color.Success : Color.Error)"/>
        </MudTd>
        <MudTd>
            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.List" OnClick="() => NavigateToDetail(dance.Id)"/>
            <AuthorizeView Roles="Admin">
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="() => OpenFormDialog(dance)"/>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.RemoveCircle" Color="Color.Error" OnClick="() => RemoveDance(dance.Id)"/>
            </AuthorizeView>
        </MudTd>
    </RowTemplate>
</MudTable>


@code {
    private List<DanceViewModel> Dances { get; set; } = new();

    private MudTable<DanceViewModel> DancesGrid { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        Dances = (await DanceService.GetAll().OrderBy(x => x.Id).ToListAsync()).Select(x => x.ToViewModel()).ToList();
    }

    private async Task RemoveDance(int id)
    {
        var resultMessage = await DialogService.ShowMessageBoxAsync("Smazat položku?", "", "Ano", "Zrušit", null, new DialogOptions() {Position = DialogPosition.Center, CloseButton = false});
        if (resultMessage.HasValue && resultMessage.Value)
        {
            await DanceService.DeleteAsync(id);
            await RefreshTable();
        }
    }

    private async Task RefreshTable()
    {
        Dances = (await DanceService.GetAll().ToListAsync()).Select(x => x.ToViewModel()).ToList();
        StateHasChanged();
    }

    private async Task OpenFormDialog(DanceViewModel? viewModel = null)
    {
        var isUpdate = viewModel is not null;
        var options = new DialogOptions {CloseOnEscapeKey = true};
        var parameters = new DialogParameters
        {
            {"IsUpdate", isUpdate},
            {"Model", viewModel ?? new DanceViewModel()}
        };
        var dialog = await DialogService.ShowAsync<DanceForm>("Dance form", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            var danceResult = result.Data as DanceViewModel;
            try
            {
                if (isUpdate)
                {
                    await DanceService.UpdateAsync(viewModel!.Id, danceResult!.ToEntity());
                    Snackbar.Add("Tanec byl upraven.", Severity.Success);
                }
                else
                {
                    await DanceService.CreateAsync(danceResult!.ToEntity());
                    Snackbar.Add("Tanec byl vytvořen.", Severity.Success);
                }

                await RefreshTable();
            }
            catch (Exception)
            {
                Snackbar.Add("Něco se pokazilo.", Severity.Error);
            }
        }
    }

    private void NavigateToDetail(int id)
    {
        NavigationManager.NavigateTo(NavigationManager.BaseUri + $"Dances/Detail/{id}");
    }

}
