@page "/Dances/Detail/{Id:int}"
@using Demizon.Core.Services.Dance
@using Demizon.Core.Services.DanceNumber
@using Demizon.Mvc.Pages.Admin.Dance.Components
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

@inject IDanceService DanceService
@inject IDanceNumberService DanceNumberService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@layout AdminMainLayout
@attribute [Authorize(Roles = "Admin, Standard")]

<PageTitle>@PageService.GetTitle()</PageTitle>

@if (Model.Id == 0)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4" Wrap="Wrap.Wrap">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"/>
        <MudText Typo="Typo.h5">@Model.Name</MudText>
        @if (!string.IsNullOrWhiteSpace(Model.Region))
        {
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">@Model.Region</MudChip>
        }
        <MudSpacer/>
        <AuthorizeView Roles="Admin">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="OpenEditDanceDialog"
                           title="Upravit tanec"/>
        </AuthorizeView>
    </MudStack>

    <MudGrid Spacing="3">

        <!-- ─── Info o tanci ─── -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.DirectionsRun" Color="Color.Primary"/>
                            <MudText Typo="Typo.h6">O tanci</MudText>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Title" IconColor="Color.Default">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Název</MudText>
                                <MudText Typo="Typo.body2">@Model.Name</MudText>
                            </MudStack>
                        </MudListItem>
                        @if (!string.IsNullOrWhiteSpace(Model.Region))
                        {
                            <MudDivider/>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Place" IconColor="Color.Default">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Region</MudText>
                                    <MudText Typo="Typo.body2">@Model.Region</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                        <MudDivider/>
                        <MudListItem T="string">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Viditelný na webu</MudText>
                                <MudIcon Icon="@(Model.IsVisible ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                         Color="@(Model.IsVisible ? Color.Success : Color.Error)" Size="Size.Small"/>
                            </MudStack>
                        </MudListItem>
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <MudDivider/>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Description" IconColor="Color.Default">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Popis</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@Model.Description</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ─── Čísla repertoáru ─── -->
        <MudItem xs="12" md="8">
            <MudCard Elevation="2" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.QueueMusic" Color="Color.Primary"/>
                            <MudText Typo="Typo.h6">Čísla repertoáru</MudText>
                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">
                                @DanceNumbers.Count
                            </MudChip>
                        </MudStack>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <AuthorizeView Roles="Admin">
                            <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                           title="Přidat číslo" OnClick="() => OpenDanceNumberDialog()"/>
                        </AuthorizeView>
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    @if (DanceNumbers.Count == 0)
                    {
                        <MudText Color="Color.Secondary" Typo="Typo.body2">Žádná čísla k zobrazení.</MudText>
                    }
                    else
                    {
                        @foreach (var number in DanceNumbers)
                        {
                            <MudPaper Outlined="true" Class="pa-3 mb-2">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudIcon Icon="@Icons.Material.Filled.MusicNote" Size="Size.Small" Color="Color.Secondary"/>
                                    <MudText Typo="Typo.subtitle2">@number.Title</MudText>
                                    <MudSpacer/>
                                    <AuthorizeView Roles="Admin">
                                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit"
                                                       OnClick="() => OpenDanceNumberDialog(number)"/>
                                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       OnClick="() => DeleteDanceNumber(number.Id)"/>
                                    </AuthorizeView>
                                </MudStack>
                                @if (!string.IsNullOrWhiteSpace(number.Description))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1 ml-6">@number.Description</MudText>
                                }
                                @if (!string.IsNullOrWhiteSpace(number.Lyrics))
                                {
                                    <MudExpansionPanels Class="mt-2" Elevation="0">
                                        <MudExpansionPanel Text="Texty písní" Dense="true">
                                            <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@number.Lyrics</MudText>
                                        </MudExpansionPanel>
                                    </MudExpansionPanels>
                                }
                            </MudPaper>
                        }
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ─── Videa (jen pokud existují) ─── -->
        @if (Model.Videos.Count > 0)
        {
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                <MudIcon Icon="@Icons.Material.Filled.VideoLibrary" Color="Color.Primary"/>
                                <MudText Typo="Typo.h6">Videa</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Správa videí v sekci <MudLink Href="@(NavigationManager.BaseUri + "Admin/Videos")">Video Links</MudLink>
                                </MudText>
                            </MudStack>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudGrid Spacing="3">
                            @foreach (var video in Model.Videos)
                            {
                                <MudItem xs="12" sm="6" md="4">
                                    <MudPaper Outlined="true">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="pa-2">
                                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">@video.Year</MudChip>
                                            <MudText Typo="Typo.subtitle2">@video.Name</MudText>
                                            @if (video.IsInternal)
                                            {
                                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Interní</MudChip>
                                            }
                                        </MudStack>
                                        <div class="demi-video-embed">
                                            <iframe src="@video.Url" title="@video.Name" allowfullscreen loading="lazy"></iframe>
                                        </div>
                                    </MudPaper>
                                </MudItem>
                            }
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }

    </MudGrid>
}

@code {
    [Parameter] public int Id { get; set; }

    private DanceViewModel Model { get; set; } = new();
    private List<DanceNumberViewModel> DanceNumbers { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        await LoadDance();
        await LoadDanceNumbers();
    }

    private async Task LoadDance()
    {
        var dance = await DanceService.GetAll()
            .Include(x => x.Videos)
            .FirstOrDefaultAsync(x => x.Id == Id);
        if (dance is null) return;
        Model = dance.ToViewModel();
        Model.Videos = dance.Videos.Select(x => x.ToViewModel()).ToList();
        PageService.SetTitle(Model.Name);
    }

    private async Task LoadDanceNumbers()
    {
        var numbers = await DanceNumberService.GetAllForDance(Id).OrderBy(x => x.Id).ToListAsync();
        DanceNumbers = numbers.Select(x => x.ToViewModel()).ToList();
    }

    private async Task OpenEditDanceDialog()
    {
        var parameters = new DialogParameters { { "IsUpdate", true }, { "Model", Model } };
        var dialog = await DialogService.ShowAsync<DanceForm>("Upravit tanec", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            var updated = result.Data as DanceViewModel;
            try
            {
                await DanceService.UpdateAsync(Id, updated!.ToEntity());
                Snackbar.Add("Tanec byl aktualizován.", Severity.Success);
                await LoadDance();
            }
            catch
            {
                Snackbar.Add("Chyba při ukládání.", Severity.Error);
            }
        }
    }

    private async Task OpenDanceNumberDialog(DanceNumberViewModel? existing = null)
    {
        var isUpdate = existing is not null;
        var model = existing is not null ? new DanceNumberViewModel
        {
            Id = existing.Id,
            Title = existing.Title,
            Description = existing.Description,
            Lyrics = existing.Lyrics,
            DanceId = existing.DanceId
        } : new DanceNumberViewModel { DanceId = Id };

        var parameters = new DialogParameters { { "IsUpdate", isUpdate }, { "Model", model } };
        var dialog = await DialogService.ShowAsync<DanceNumberForm>("Číslo tance", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            var data = result.Data as DanceNumberViewModel;
            try
            {
                if (isUpdate)
                    await DanceNumberService.UpdateAsync(existing!.Id, data!.ToEntity());
                else
                    await DanceNumberService.CreateAsync(data!.ToEntity());

                Snackbar.Add(isUpdate ? "Číslo bylo aktualizováno." : "Číslo bylo přidáno.", Severity.Success);
                await LoadDanceNumbers();
            }
            catch
            {
                Snackbar.Add("Chyba při ukládání.", Severity.Error);
            }
        }
    }

    private async Task DeleteDanceNumber(int id)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Smazat číslo?", "", "Smazat", "Zrušit");
        if (confirm is true)
        {
            await DanceNumberService.DeleteAsync(id);
            Snackbar.Add("Číslo bylo smazáno.", Severity.Success);
            await LoadDanceNumbers();
        }
    }

    private void GoBack() => NavigationManager.NavigateTo(NavigationManager.BaseUri + "Admin/Dances");
}
