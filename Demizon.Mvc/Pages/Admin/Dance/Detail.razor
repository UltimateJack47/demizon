@page "/Dances/Detail/{Id:int}"
@using Demizon.Core.Services.File
@using Demizon.Core.Services.FileUpload
@using Demizon.Core.Services.Dance
@using Demizon.Core.Services.VideoLink
@using Demizon.Dal.Entities
@using Demizon.Mvc.Pages.Admin.Dance.Components
@using Demizon.Mvc.Pages.Admin.VideoLink.Components
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

@inject IFileService FileService
@inject IFileUploadService FileUploadService
@inject IDanceService DanceService
@inject IVideoLinkService VideoLinkService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

@layout AdminMainLayout
@attribute [Authorize(Roles = "Admin, Standard")]

<PageTitle>@PageService.GetTitle()</PageTitle>

@if (Model.Id == 0)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary"/>
}
else
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4" Wrap="Wrap.Wrap">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack"/>
        <MudText Typo="Typo.h5">@Model.Name</MudText>
        @if (!string.IsNullOrWhiteSpace(Model.Region))
        {
            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small">@Model.Region</MudChip>
        }
        <MudSpacer/>
        <AuthorizeView Roles="Admin">
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" OnClick="OpenEditDanceDialog"
                           title="Upravit tanec"/>
        </AuthorizeView>
    </MudStack>

    <MudGrid Spacing="3">

        <!-- ─── Info o tanci ─── -->
        <MudItem xs="12" md="4">
            <MudCard Elevation="2" Style="height: 100%;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.DirectionsRun" Color="Color.Primary"/>
                            <MudText Typo="Typo.h6">O tanci</MudText>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Title" IconColor="Color.Default">
                            <MudStack Spacing="0">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Název</MudText>
                                <MudText Typo="Typo.body2">@Model.Name</MudText>
                            </MudStack>
                        </MudListItem>
                        @if (!string.IsNullOrWhiteSpace(Model.Region))
                        {
                            <MudDivider/>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Place" IconColor="Color.Default">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Region</MudText>
                                    <MudText Typo="Typo.body2">@Model.Region</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                        <MudDivider/>
                        <MudListItem T="string">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudText Typo="Typo.body2">Viditelný na webu</MudText>
                                <MudIcon Icon="@(Model.IsVisible ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                                         Color="@(Model.IsVisible ? Color.Success : Color.Error)" Size="Size.Small"/>
                            </MudStack>
                        </MudListItem>
                        @if (!string.IsNullOrWhiteSpace(Model.Description))
                        {
                            <MudDivider/>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Public" IconColor="Color.Default">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Veřejný popis</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@Model.Description</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.InternalDescription))
                        {
                            <MudDivider/>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Lock" IconColor="Color.Warning">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Interní popis</MudText>
                                    <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@Model.InternalDescription</MudText>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                    @if (!string.IsNullOrWhiteSpace(Model.Lyrics))
                    {
                        <MudDivider Class="my-2"/>
                        <MudExpansionPanels Elevation="0">
                            <MudExpansionPanel Text="Texty písní" Dense="true">
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap;">@Model.Lyrics</MudText>
                            </MudExpansionPanel>
                        </MudExpansionPanels>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- ─── Taby: Videa / Fotky / Dokumenty ─── -->
        <MudItem xs="12" md="8">
            <MudCard Elevation="2" Style="height: 100%;">
                <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true">

                    <!-- Videa -->
                    <MudTabPanel Icon="@Icons.Material.Filled.VideoLibrary" Text="@($"Videa ({Model.Videos.Count})")">
                        <div class="pa-4">
                            <AuthorizeView Roles="Admin">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1" Class="mb-3">
                                    <MudTooltip Text="Propojit existující video">
                                        <MudIconButton Icon="@Icons.Material.Filled.Link" Color="Color.Secondary"
                                                       OnClick="OpenLinkVideoDialog"/>
                                    </MudTooltip>
                                    <MudTooltip Text="Přidat nové video">
                                        <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary"
                                                       OnClick="OpenCreateVideoDialog"/>
                                    </MudTooltip>
                                </MudStack>
                            </AuthorizeView>
                            @if (Model.Videos.Count == 0)
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.body2" Align="Align.Center" Class="py-6">
                                    Žádná videa k zobrazení.
                                </MudText>
                            }
                            else
                            {
                                <MudGrid Spacing="2">
                                    @foreach (var video in Model.Videos)
                                    {
                                        <MudItem xs="12" lg="6">
                                            <MudPaper Outlined="true">
                                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="pa-2">
                                                    <MudChip T="string" Size="Size.Small" Color="Color.Primary">@video.Year</MudChip>
                                                    <MudLink Href="@($"/Videos/Detail/{video.Id}")" Typo="Typo.subtitle2">@video.Name</MudLink>
                                                    @if (video.IsInternal)
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Interní</MudChip>
                                                    }
                                                    <MudSpacer/>
                                                    <AuthorizeView Roles="Admin">
                                                        <MudTooltip Text="Odpojit video od tance">
                                                            <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.LinkOff"
                                                                           Color="Color.Warning"
                                                                           OnClick="() => UnlinkVideo(video.Id)"/>
                                                        </MudTooltip>
                                                    </AuthorizeView>
                                                </MudStack>
                                                <div class="demi-video-embed">
                                                    <iframe src="@video.Url" title="@video.Name" allowfullscreen loading="lazy"></iframe>
                                                </div>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                        </div>
                    </MudTabPanel>

                    <!-- Fotky -->
                    <MudTabPanel Icon="@Icons.Material.Filled.PhotoLibrary" Text="@($"Fotky ({Photos.Count})")">
                        <div class="pa-4">
                            <AuthorizeView Roles="Admin">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd" Spacing="1" Class="mb-3">
                                    <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadDancePhotos" Accept="image/*">
                                        <CustomContent Context="upload">
                                            <MudTooltip Text="Nahrát fotky k tanci">
                                                <MudIconButton Icon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary"
                                                               OnClick="@upload.OpenFilePickerAsync"
                                                               Disabled="@_uploadingPhotos"/>
                                            </MudTooltip>
                                        </CustomContent>
                                    </MudFileUpload>
                                </MudStack>
                            </AuthorizeView>
                            @if (Photos.Count == 0)
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.body2" Align="Align.Center" Class="py-6">
                                    Žádné fotografie k zobrazení.
                                </MudText>
                            }
                            else
                            {
                                <MudGrid Spacing="2">
                                    @foreach (var photo in Photos)
                                    {
                                        <MudItem xs="6" sm="4" md="4" lg="3">
                                            <MudPaper Outlined="true" Class="pa-1" Style="position: relative;">
                                                <img src="/api/files/@photo.Id/image?size=thumb" alt="photo"
                                                     style="width:100%; aspect-ratio:1; object-fit:cover; border-radius:4px; display:block;"/>
                                                <AuthorizeView Roles="Admin">
                                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-1">
                                                        <MudTooltip Text="@(photo.IsPublic ? "Veřejné – viditelné na webu" : "Soukromé – pouze v admin")">
                                                            <MudSwitch T="bool" Value="@photo.IsPublic"
                                                                       ValueChanged="@((bool val) => TogglePhotoPublic(photo, val))"
                                                                       Color="Color.Success" Size="Size.Small"/>
                                                        </MudTooltip>
                                                        <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete"
                                                                       Color="Color.Error" OnClick="() => DeleteDancePhoto(photo.Id)"/>
                                                    </MudStack>
                                                </AuthorizeView>
                                            </MudPaper>
                                        </MudItem>
                                    }
                                </MudGrid>
                            }
                        </div>
                    </MudTabPanel>

                    <!-- Dokumenty -->
                    <MudTabPanel Icon="@Icons.Material.Filled.Description" Text="@($"Dokumenty ({Documents.Count})")">
                        <div class="pa-4">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Outlined">Jen pro členy</MudChip>
                                <MudSpacer/>
                                <AuthorizeView Roles="Admin">
                                    <MudFileUpload T="IReadOnlyList<IBrowserFile>" FilesChanged="UploadDanceDocuments"
                                                   Accept=".pdf,.doc,.docx,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document">
                                        <CustomContent Context="upload">
                                            <MudTooltip Text="Nahrát dokument (PDF / DOCX)">
                                                <MudIconButton Icon="@Icons.Material.Filled.UploadFile" Color="Color.Primary"
                                                               OnClick="@upload.OpenFilePickerAsync"
                                                               Disabled="@_uploadingDocuments"/>
                                            </MudTooltip>
                                        </CustomContent>
                                    </MudFileUpload>
                                </AuthorizeView>
                            </MudStack>
                            @if (Documents.Count == 0)
                            {
                                <MudText Color="Color.Secondary" Typo="Typo.body2" Align="Align.Center" Class="py-6">
                                    Žádné dokumenty k zobrazení.
                                </MudText>
                            }
                            else
                            {
                            <MudList T="string" Dense="true">
                                @foreach (var doc in Documents)
                                {
                                    <MudListItem T="string" Icon="@DocumentIcon(doc.ContentType)" IconColor="Color.Primary">
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                            <MudStack Spacing="0" Style="flex: 1; min-width: 0;">
                                                <MudLink Href="@($"/api/files/{doc.Id}/document")" Target="_blank" Typo="Typo.body2">
                                                    @System.IO.Path.GetFileName(doc.Path)
                                                </MudLink>
                                                <MudText Typo="Typo.caption" Color="Color.Secondary">@FormatFileSize(doc.FileSize)</MudText>
                                            </MudStack>
                                            <AuthorizeView Roles="Admin">
                                                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Delete"
                                                               Color="Color.Error" OnClick="() => DeleteDanceDocument(doc.Id)"/>
                                            </AuthorizeView>
                                        </MudStack>
                                    </MudListItem>
                                }
                            </MudList>
                            }
                        </div>
                    </MudTabPanel>

                </MudTabs>
            </MudCard>
        </MudItem>

    </MudGrid>
}

@code {

    [Parameter] public int Id { get; set; }

    private DanceViewModel Model { get; set; } = new();

    private List<FileViewModel> Photos => Model.Files.Where(f => f.Kind == FileKind.Image).ToList();
    private List<FileViewModel> Documents => Model.Files.Where(f => f.Kind == FileKind.Document).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadDance();
    }

    private async Task LoadDance()
    {
        var dance = await DanceService.GetAll()
            .Include(x => x.Videos)
            .Include(x => x.Files)
            .FirstOrDefaultAsync(x => x.Id == Id);
        if (dance is null) return;
        Model = dance.ToViewModel();
        Model.Videos = dance.Videos.OrderByDescending(x => x.Year).Select(x => x.ToViewModel()).ToList();
        Model.Files = dance.Files
            .Where(f => f.Data != null)
            .OrderBy(f => f.Kind)
            .ThenByDescending(f => f.Id)
            .Select(f => f.ToViewModel())
            .ToList();
        PageService.SetTitle(Model.Name);
    }

    private async Task OpenEditDanceDialog()
    {
        var parameters = new DialogParameters { { "IsUpdate", true }, { "Model", Model } };
        var dialog = await DialogService.ShowAsync<DanceForm>("Upravit tanec", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            var updated = result.Data as DanceViewModel;
            try
            {
                await DanceService.UpdateAsync(Id, updated!.ToEntity());
                Snackbar.Add("Tanec byl aktualizován.", Severity.Success);
                await LoadDance();
            }
            catch
            {
                Snackbar.Add("Chyba při ukládání.", Severity.Error);
            }
        }
    }

    private async Task OpenCreateVideoDialog()
    {
        var newVideo = new VideoLinkViewModel { DanceId = Id };
        var parameters = new DialogParameters { { "IsUpdate", false }, { "Model", newVideo } };
        var dialog = await DialogService.ShowAsync<VideoLinkForm>("Přidat video", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            var data = result.Data as VideoLinkViewModel;
            try
            {
                await VideoLinkService.CreateAsync(data!.ToEntity());
                Snackbar.Add("Video bylo přidáno.", Severity.Success);
                await LoadDance();
            }
            catch
            {
                Snackbar.Add("Chyba při ukládání videa.", Severity.Error);
            }
        }
    }

    private async Task OpenLinkVideoDialog()
    {
        var parameters = new DialogParameters { { "DanceId", Id } };
        var dialog = await DialogService.ShowAsync<LinkVideoDialog>("Propojit video s tancem", parameters);
        var result = await dialog.Result;
        if (!result!.Canceled)
        {
            await LoadDance();
        }
    }

    private async Task UnlinkVideo(int videoId)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Odpojit video?",
            "Video zůstane v systému, pouze nebude propojeno s tímto tancem.", "Odpojit", "Zrušit");
        if (confirm is true)
        {
            try
            {
                var entity = await VideoLinkService.GetOneAsync(videoId);
                entity.DanceId = null;
                await VideoLinkService.UpdateAsync(videoId, entity);
                Snackbar.Add("Video bylo odpojeno.", Severity.Success);
                await LoadDance();
            }
            catch
            {
                Snackbar.Add("Chyba při odpojování videa.", Severity.Error);
            }
        }
    }

    private void GoBack() => NavigationManager.NavigateTo(NavigationManager.BaseUri + "Admin/Dances");

    // ─── Photo management ───

    private bool _uploadingPhotos;

    private async Task UploadDancePhotos(IReadOnlyList<IBrowserFile> files)
    {
        _uploadingPhotos = true;
        StateHasChanged();

        try
        {
            foreach (var file in files)
            {
                await using var stream = file.OpenReadStream(25 * 1024 * 1024);
                var result = await FileUploadService.UploadImageToDbAsync(new FileUploadRequest
                {
                    Stream = stream,
                    FileExtension = System.IO.Path.GetExtension(file.Name),
                    FileName = System.IO.Path.GetFileNameWithoutExtension(file.Name),
                    FileSize = file.Size,
                    ContentType = file.ContentType
                });

                if (result.IsSuccessful)
                {
                    var entity = new Dal.Entities.File
                    {
                        Path = result.RelativePath,
                        FileExtension = result.FileExtension,
                        ContentType = result.ContentType,
                        FileSize = result.FileSize,
                        Data = result.Data,
                        ThumbnailData = result.ThumbnailData,
                        IsPublic = false,
                        DanceId = Id,
                        Kind = FileKind.Image
                    };
                    await FileService.CreateAsync(entity);
                }
            }

            Snackbar.Add($"Nahráno {files.Count} foto k tanci.", Severity.Success);
            await LoadDance();
        }
        catch
        {
            Snackbar.Add("Nahrávání se nezdařilo.", Severity.Error);
        }
        finally
        {
            _uploadingPhotos = false;
            StateHasChanged();
        }
    }

    private async Task TogglePhotoPublic(FileViewModel photo, bool value)
    {
        try
        {
            var entity = await FileService.GetOneAsync(photo.Id);
            entity.IsPublic = value;
            await FileService.UpdateAsync(photo.Id, entity);
            photo.IsPublic = value;
            StateHasChanged();
        }
        catch
        {
            Snackbar.Add("Nepodařilo se změnit viditelnost fotky.", Severity.Error);
        }
    }

    private async Task DeleteDancePhoto(int id)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Smazat fotografii?",
            "Fotografie bude trvale smazána.", "Ano", "Zrušit", null,
            new DialogOptions { Position = DialogPosition.Center, CloseButton = false });
        if (confirm is true)
        {
            await FileService.DeleteAsync(id);
            await LoadDance();
            Snackbar.Add("Fotografie smazána.", Severity.Success);
        }
    }

    // ─── Document management ───

    private bool _uploadingDocuments;

    private static readonly string[] AllowedDocExtensions = { ".pdf", ".doc", ".docx" };

    private async Task UploadDanceDocuments(IReadOnlyList<IBrowserFile> files)
    {
        _uploadingDocuments = true;
        StateHasChanged();

        try
        {
            var uploaded = 0;
            foreach (var file in files)
            {
                var ext = System.IO.Path.GetExtension(file.Name).ToLowerInvariant();
                if (!AllowedDocExtensions.Contains(ext))
                {
                    Snackbar.Add($"Soubor {file.Name} není podporovaný formát.", Severity.Warning);
                    continue;
                }

                await using var stream = file.OpenReadStream(25 * 1024 * 1024);
                var result = await FileUploadService.UploadDocumentToDbAsync(new FileUploadRequest
                {
                    Stream = stream,
                    FileExtension = ext,
                    FileName = file.Name,
                    FileSize = file.Size,
                    ContentType = file.ContentType
                });

                if (result.IsSuccessful)
                {
                    var entity = new Dal.Entities.File
                    {
                        Path = file.Name,
                        FileExtension = result.FileExtension,
                        ContentType = result.ContentType,
                        FileSize = result.FileSize,
                        Data = result.Data,
                        ThumbnailData = null,
                        IsPublic = false,
                        DanceId = Id,
                        Kind = FileKind.Document
                    };
                    await FileService.CreateAsync(entity);
                    uploaded++;
                }
            }

            if (uploaded > 0)
                Snackbar.Add($"Nahráno {uploaded} dokumentů k tanci.", Severity.Success);
            await LoadDance();
        }
        catch
        {
            Snackbar.Add("Nahrávání dokumentu se nezdařilo.", Severity.Error);
        }
        finally
        {
            _uploadingDocuments = false;
            StateHasChanged();
        }
    }

    private async Task DeleteDanceDocument(int id)
    {
        var confirm = await DialogService.ShowMessageBoxAsync("Smazat dokument?",
            "Dokument bude trvale smazán.", "Ano", "Zrušit", null,
            new DialogOptions { Position = DialogPosition.Center, CloseButton = false });
        if (confirm is true)
        {
            await FileService.DeleteAsync(id);
            await LoadDance();
            Snackbar.Add("Dokument smazán.", Severity.Success);
        }
    }

    private static string DocumentIcon(string contentType) => contentType switch
    {
        "application/pdf" => Icons.Material.Filled.PictureAsPdf,
        "application/msword" => Icons.Material.Filled.Description,
        "application/vnd.openxmlformats-officedocument.wordprocessingml.document" => Icons.Material.Filled.Description,
        _ => Icons.Material.Filled.InsertDriveFile
    };

    private static string FormatFileSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.#} kB";
        return $"{bytes / (1024.0 * 1024.0):0.##} MB";
    }
}
