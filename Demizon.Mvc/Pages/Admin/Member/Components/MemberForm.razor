@using System.Security.Claims
@using Demizon.Core.Services.FileUpload
@using Demizon.Core.Services.Member
@using Demizon.Dal.Entities
@using Demizon.Mvc.Helpers
@using Demizon.Mvc.ViewModels
@using Color = MudBlazor.Color
<MudDialog Style="min-width: min(520px, calc(100vw - 32px))">
    <TitleContent>
        <MudText Typo="Typo.h6">
            @(IsUpdate ? "Upravit" : "Vytvořit") - Člen
        </MudText>
    </TitleContent>

    <DialogContent>
        <MudGrid Spacing="2">
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.Name" T="string" Label="Jméno" Required="true" RequiredError="Jméno je povinné!"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="Model.Surname" T="string" Label="Příjmení"
                              Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            @if (!Model.IsExternal)
            {
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Login" T="string" Label="Login" Required="true" RequiredError="Login je povinný!"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"/>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="Model.Email" T="string" Label="E-mail" Required="true" RequiredError="E-mail je povinný!"
                                  Variant="Variant.Outlined" Margin="Margin.Dense"
                                  Validation="@((Func<string?, string?>)ValidationHelpers.ValidateEmail)"/>
                </MudItem>
                @if ((IsUpdate && (Model.Id == LoggedUser.Id)) || !IsUpdate)
                {
                    <MudItem xs="12">
                        <MudTextField @bind-Value="Model.Password" T="string"
                                      Label="@(IsUpdate ? "Nové heslo (ponech prázdné pro zachování)" : "Heslo")"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      InputType="@_passwordInput" Adornment="Adornment.End"
                                      AdornmentIcon="@_passwordInputIcon" OnAdornmentClick="ChangeIsShow"
                                      Required="@(!IsUpdate)" RequiredError="Heslo je povinné!"/>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_passwordConfirm" T="string"
                                      Label="@(IsUpdate ? "Nové heslo znovu" : "Heslo znovu")"
                                      Variant="Variant.Outlined" Margin="Margin.Dense"
                                      InputType="@_passwordInput" Adornment="Adornment.End"
                                      AdornmentIcon="@_passwordInputIcon" OnAdornmentClick="ChangeIsShow"
                                      Required="@(!IsUpdate)" RequiredError="Heslo je povinné!"
                                      Error="@PasswordMismatch" ErrorText="Hesla se neshodují"
                                      Disabled="@(string.IsNullOrEmpty(Model.Password))"/>
                    </MudItem>
                }
            }
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="Model.MemberSince" Label="Členem od"
                               Clearable="true" Editable="true" MaxDate="DateTime.Today"
                               Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="Model.BirthDate" Label="Narozeniny"
                               Clearable="true" Editable="true" MaxDate="DateTime.Today"
                               Variant="Variant.Outlined" Margin="Margin.Dense"/>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="Model.Gender" Label="Pohlaví" T="Gender"
                           Variant="Variant.Outlined" Margin="Margin.Dense">
                    @foreach (Gender item in Enum.GetValues(typeof(Gender)))
                    {
                        <MudSelectItem Value="@item">@item</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="6" Class="d-flex align-center">
                <MudFileUpload T="IBrowserFile" FilesChanged="UploadFile" Accept="image/*">
                    <CustomContent Context="upload">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.CloudUpload"
                                   OnClick="@upload.OpenFilePickerAsync" Style="width: 100%;">
                            Profilovka
                        </MudButton>
                    </CustomContent>
                </MudFileUpload>
            </MudItem>
            @if (File is not null)
            {
                <MudItem xs="12">
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.AttachFile" @key="@File">
                            @File.Name <code>@File.Size bytes</code>
                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircle" OnClick="RemoveFile" Size="Size.Small"/>
                        </MudListItem>
                    </MudList>
                </MudItem>
            }
            @if (LoggedUser.Role == UserRole.Admin)
            {
                <MudItem xs="12">
                    <MudDivider Class="my-1"/>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-1">Nastavení admina</MudText>
                    <MudGrid Spacing="0">
                        <MudItem xs="12">
                            <MudCheckBox T="bool" Value="Model.IsExternal" Label="Externista (zastupující člen)"
                                         Color="Color.Warning" ValueChanged="OnIsExternalChanged"/>
                        </MudItem>
                        @if (!Model.IsExternal)
                        {
                            <MudItem xs="6">
                                <MudCheckBox @bind-Value="Model.IsVisible" Label="Veřejné" Color="Color.Primary"/>
                            </MudItem>
                        }
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="Model.IsAttendanceVisible" Label="Zobrazovat v docházce" Color="Color.Primary"/>
                        </MudItem>
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="Model.IsDancer" Label="Tanec" Color="Color.Primary"/>
                        </MudItem>
                        <MudItem xs="6">
                            <MudCheckBox @bind-Value="Model.IsMusician" Label="Muzika" Color="Color.Primary"/>
                        </MudItem>
                    </MudGrid>
                </MudItem>
            }
        </MudGrid>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Zrušit</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ClickedOk">
            @(IsUpdate ? "Upravit" : "Vytvořit")
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Inject] IMemberService MemberService { get; set; } = null!;
    [Inject] private IFileUploadService FileUploadService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public Task<AuthenticationState>? AuthenticationState { get; set; }

    [Parameter] public MemberViewModel Model { get; set; } = new();


    [Parameter] public bool IsUpdate { get; set; }

    private MemberViewModel LoggedUser { get; set; } = new();
    bool _isShow;
    InputType _passwordInput = InputType.Password;
    string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
    private string _passwordConfirm = string.Empty;
    private bool PasswordMismatch =>
        !string.IsNullOrEmpty(Model.Password) &&
        !string.IsNullOrEmpty(_passwordConfirm) &&
        Model.Password != _passwordConfirm;

    private IBrowserFile? File { get; set; }

    protected override void OnInitialized()
    {
        var loggedUserLogin = AuthenticationState?.Result.User.Claims.First(x => x.Type == ClaimTypes.Name).Value;
        LoggedUser = MemberService.GetOneByLogin(loggedUserLogin)!.ToViewModel();
    }

    private async Task ClickedOk()
    {
        if (!string.IsNullOrEmpty(Model.Password) && Model.Password != _passwordConfirm)
        {
            Snackbar.Add("Hesla se neshodují.", Severity.Error);
            return;
        }

        if (!Model.IsExternal && ValidationHelpers.ValidateEmail(Model.Email) is { } emailError)
        {
            Snackbar.Add(emailError, Severity.Error);
            return;
        }

        try
        {
            var dbModel = Model.ToEntity();

            if (File is not null)
            {
                await using var stream = File.OpenReadStream(25 * 1024 * 1024);
                var result = await FileUploadService.UploadImageToDbAsync(new FileUploadRequest
                {
                    Stream = stream,
                    FileExtension = Path.GetExtension(File.Name),
                    FileName = Path.GetFileNameWithoutExtension(File.Name),
                    FileSize = File.Size,
                    ContentType = File.ContentType
                });

                if (result.IsSuccessful)
                {
                    var photo = new Dal.Entities.File
                    {
                        MemberId = Model.Id,
                        Path = result.RelativePath,
                        ContentType = result.ContentType,
                        FileSize = result.FileSize,
                        FileExtension = result.FileExtension,
                        Data = result.Data,
                        ThumbnailData = result.ThumbnailData,
                    };
                    dbModel.Photos.Add(photo);
                }
            }

            if (IsUpdate)
            {
                await MemberService.UpdateAsync(Model.Id, dbModel);
            }
            else
            {
                await MemberService.CreateAsync(dbModel);
            }

            Snackbar.Add(IsUpdate ? "Člen byl upraven." : "Člen byl vytvořen.", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception)
        {
            Snackbar.Add("Něco se pokazilo.", Severity.Error);
            MudDialog.Close(DialogResult.Ok(false));
        }
    }

    private void UploadFile(IBrowserFile file)
    {
        File = file;
    }

    private void RemoveFile()
    {
        File = null;
    }

    void ChangeIsShow()
    {
        @if (_isShow)
        {
            _isShow = false;
            _passwordInputIcon = Icons.Material.Filled.VisibilityOff;
            _passwordInput = InputType.Password;
        }
        else
        {
            _isShow = true;
            _passwordInputIcon = Icons.Material.Filled.Visibility;
            _passwordInput = InputType.Text;
        }
    }

    private string? _originalLogin;
    private string? _originalPassword;

    private void OnIsExternalChanged(bool value)
    {
        Model.IsExternal = value;
        if (value)
        {
            _originalLogin = Model.Login;
            _originalPassword = Model.Password;
            Model.IsVisible = false;
            Model.Login = $"ext-{Guid.NewGuid():N}"[..16];
            Model.Password = Guid.NewGuid().ToString("N");
            Model.Email = null;
        }
        else
        {
            Model.Login = _originalLogin ?? Model.Login;
            Model.Password = _originalPassword;
            _originalLogin = null;
            _originalPassword = null;
        }
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

}