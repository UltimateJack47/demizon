@page "/Admin/Videos"
@using Demizon.Core.Services.VideoLink
@using Demizon.Mvc.Pages.Admin.VideoLink.Components
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

<PageTitle>@PageService.GetTitle()</PageTitle>

@inject IVideoLinkService VideoLinkService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@attribute [Authorize(Roles = "Admin")]
@layout AdminMainLayout

<MudTable @ref="VideoLinksGrid" T="VideoLinkViewModel" Items="VideoLinks" Hover="true" Striped="true" FixedHeader="true" Height="900px">
    <ToolBarContent>
        <MudText Typo="Typo.subtitle1"><b>Video odkazy</b></MudText>
        <MudSpacer/>
        <MudIconButton Class="mt-0" Size="Size.Medium" aria-label="refresh" OnClick="RefreshTable" Icon="@Icons.Material.Filled.Refresh"></MudIconButton>
        <MudButton Size="Size.Medium" Variant="Variant.Filled" ButtonType="ButtonType.Button" Color="Color.Primary" @onclick="() => OpenFormDialog()">Vytvořit</MudButton>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<VideoLinkViewModel, object>(x => x.Name)"><b>Název</b></MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortBy="new Func<VideoLinkViewModel, object>(x => x.Year)" InitialDirection="SortDirection.Descending"><b>Rok</b></MudTableSortLabel>
        </MudTh>
        <MudTh>
            <b>URL</b>
        </MudTh>
        <MudTh>
            <b>Veřejné</b>
        </MudTh>
        <MudTh Style="width: 40px"></MudTh>
    </HeaderContent>
    <RowTemplate Context="videoLink">
        <MudTd>@videoLink.Name</MudTd>
        <MudTd>@videoLink.Year</MudTd>
        <MudTd>@videoLink.Url</MudTd>
        <MudTd>
            <MudIcon Icon="@(videoLink.IsVisible ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)"
                     Color="@(videoLink.IsVisible ? Color.Success : Color.Error)"/>
        </MudTd>
        <MudTd>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="0" Style="white-space: nowrap;">
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Visibility" OnClick="() => NavigateToDetail(videoLink.Id)" title="Detail"/>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.Edit" OnClick="() => OpenFormDialog(videoLink)"/>
                <MudIconButton Size="Size.Small" Icon="@Icons.Material.Filled.RemoveCircle" OnClick="() => RemoveVideoLink(videoLink.Id)"/>
            </MudStack>
        </MudTd>
    </RowTemplate>
</MudTable>


@code {
    private List<VideoLinkViewModel> VideoLinks { get; set; } = new();

    private MudTable<VideoLinkViewModel> VideoLinksGrid { get; set; } = null!;

    protected override async Task OnInitializedAsync()
    {
        PageService.SetTitle("Video odkazy");
        VideoLinks = (await VideoLinkService.GetAll().OrderByDescending(x => x.Year).ToListAsync()).Select(x => x.ToViewModel()).ToList();
    }

    private async Task RemoveVideoLink(int id)
    {
        var resultMessage = await DialogService.ShowMessageBoxAsync("Smazat položku?", "", "Ano", "Zrušit", null, new DialogOptions() {Position = DialogPosition.Center, CloseButton = false});
        if (resultMessage.HasValue && resultMessage.Value)
        {
            await VideoLinkService.DeleteAsync(id);
            await RefreshTable();
        }
    }

    private async Task RefreshTable()
    {
        VideoLinks = (await VideoLinkService.GetAll().ToListAsync()).Select(x => x.ToViewModel()).ToList();
        StateHasChanged();
    }

    private async Task OpenFormDialog(VideoLinkViewModel? viewModel = null)
    {
        var isUpdate = viewModel is not null;
        var options = new DialogOptions {CloseOnEscapeKey = true};
        var parameters = new DialogParameters
        {
            {"IsUpdate", isUpdate},
            {"Model", viewModel ?? new VideoLinkViewModel()}
        };
        var dialog = await DialogService.ShowAsync<VideoLinkForm>("Video Link form", parameters, options);
        var result = await dialog.Result;

        if (!result!.Canceled)
        {
            var linkResult = result.Data as VideoLinkViewModel;
            try
            {
                if (isUpdate)
                {
                    await VideoLinkService.UpdateAsync(viewModel!.Id, linkResult!.ToEntity());
                    Snackbar.Add("Video odkaz byl upraven.", Severity.Success);
                }
                else
                {
                    await VideoLinkService.CreateAsync(linkResult!.ToEntity());
                    Snackbar.Add("Video odkaz byl vytvořen.", Severity.Success);
                }

                await RefreshTable();
            }
            catch (Exception)
            {
                Snackbar.Add("Něco se pokazilo.", Severity.Error);
            }
        }
    }

    private void NavigateToDetail(int id)
    {
        NavigationManager.NavigateTo(NavigationManager.BaseUri + $"Videos/Detail/{id}");
    }

}
