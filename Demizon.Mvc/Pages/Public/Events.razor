@page "/Events"
@using Demizon.Core.Services.Event
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

<PageTitle>@PageService.GetTitle()</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@Localizer[nameof(DemizonLocales.UpcomingEvents)]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@Localizer[nameof(DemizonLocales.EventsSubtitle)]</MudText>

@if (UpcomingEvents.Count == 0)
{
    <MudCard Elevation="1" Class="pa-4">
        <MudStack AlignItems="AlignItems.Center" Spacing="0">
        <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" Style="font-size: 3rem;"/>
        <MudText Typo="Typo.h6" Class="mt-2" Align="Align.Center">@Localizer[nameof(DemizonLocales.NoUpcomingEventsPageHeader)]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3" Align="Align.Center">@Localizer[nameof(DemizonLocales.NoUpcomingEventsPageText)]</MudText>
        <MudStack Row="true" Justify="Justify.Center" Spacing="2" Wrap="Wrap.Wrap" Class="mb-2">
            <MudButton Variant="Variant.Filled"
                       Style="background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fd5949 45%, #d6249f 60%, #285AEB 90%); color: white;"
                       Href="https://www.instagram.com/fs_demizon/" Target="_blank"
                       StartIcon="@Icons.Custom.Brands.Instagram">
                Instagram
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Style="background: #1877F2; color: white;"
                       Href="https://www.facebook.com/fs.demizon" Target="_blank"
                       StartIcon="@Icons.Custom.Brands.Facebook">
                Facebook
            </MudButton>
        </MudStack>
        <MudLink Href="/Contact" Color="Color.Secondary" Typo="Typo.caption">
            @Localizer[nameof(DemizonLocales.ContactUsButton)]
        </MudLink>
        </MudStack>
    </MudCard>
}
else
{
    <MudTimeline TimelinePosition="TimelinePosition.Left">
        @foreach (var upcomingEvent in UpcomingEvents)
        {
            <MudTimelineItem Color="Color.Primary" Size="Size.Medium" Elevation="2">
                <ItemContent>
                    <MudCard Elevation="2" Class="mb-2">
                        <MudCardContent Class="py-3">
                            <MudText Typo="Typo.subtitle1"><strong>@upcomingEvent.Name</strong></MudText>
                            @if (!string.IsNullOrWhiteSpace(upcomingEvent.Place))
                            {
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-1">
                                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Color="Color.Secondary"/>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@upcomingEvent.Place</MudText>
                                </MudStack>
                            }
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-1">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarToday" Size="Size.Small" Color="Color.Primary"/>
                                <MudText Typo="Typo.body2" Color="Color.Primary">
                                    @if (upcomingEvent.Date.Start?.Date == upcomingEvent.Date.End?.Date)
                                    {
                                        @upcomingEvent.Date.Start?.ToString("d. MMMM yyyy")
                                    }
                                    else
                                    {
                                        @($"{upcomingEvent.Date.Start?.ToString("d. MMMM")} – {upcomingEvent.Date.End?.ToString("d. MMMM yyyy")}")
                                    }
                                </MudText>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                </ItemContent>
            </MudTimelineItem>
        }
    </MudTimeline>
}

@code {

    [Inject] private IEventService EventService { get; set; } = null!;

    private List<EventViewModel> UpcomingEvents { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        PageService.SetTitle(Localizer[nameof(DemizonLocales.UpcomingEvents)]);
        var events = await EventService.GetAll()
            .Where(x => x.DateTo >= DateTime.Today && x.IsPublic && !x.IsCancelled)
            .OrderBy(x => x.DateTo)
            .ToListAsync();
        UpcomingEvents = events.Select(x => x.ToViewModel()).ToList();
    }

}
