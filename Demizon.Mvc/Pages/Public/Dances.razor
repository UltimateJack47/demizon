@page "/Dances"
@using Demizon.Core.Services.Dance
@using Demizon.Dal.Entities
@using Demizon.Mvc.Pages.Public.Components
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

@inject IDialogService DialogService

<PageTitle>@PageService.GetTitle()</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@Localizer[nameof(DemizonLocales.Dances)]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    @Localizer[nameof(DemizonLocales.DancesSubtitle)]
</MudText>

@if (VisibleDances.Count == 0)
{
    <MudText Typo="Typo.body1" Color="Color.Secondary">@Localizer[nameof(DemizonLocales.DancesEmpty)]</MudText>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var dance in VisibleDances)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="2" Class="demi-dance-card">
                    <MudCardContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.AccessibilityNew" Color="Color.Primary"/>
                            <MudText Typo="Typo.h6">@dance.Name</MudText>
                        </MudStack>
                        @if (!string.IsNullOrWhiteSpace(dance.Region))
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined" Class="mb-2">
                                @dance.Region
                            </MudChip>
                        }
                        @if (!string.IsNullOrWhiteSpace(dance.Description))
                        {
                            <MudText Typo="Typo.body2" Class="mt-2">@dance.Description</MudText>
                        }

                        @{
                            var publicVideos = dance.Videos.Where(v => v.IsVisible && !v.IsInternal).ToList();
                            var publicPhotos = dance.Files
                                .Where(f => f.IsPublic && f.Kind == FileKind.Image)
                                .ToList();
                        }

                        @if (publicVideos.Any())
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.OndemandVideo" Size="Size.Small" Class="mr-1" />
                                @Localizer[nameof(DemizonLocales.Videos)]
                            </MudText>
                            @foreach (var video in publicVideos)
                            {
                                <MudLink Href="@video.Url" Target="_blank" Typo="Typo.body2" Class="d-block">
                                    ▶ @video.Name (@video.Year)
                                </MudLink>
                            }
                        }

                        @if (publicPhotos.Any())
                        {
                            <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">
                                <MudIcon Icon="@Icons.Material.Filled.PhotoLibrary" Size="Size.Small" Class="mr-1" />
                                @Localizer[nameof(DemizonLocales.Photos)]
                            </MudText>
                            <div class="demi-gallery-grid" style="gap: 6px;">
                                @for (var i = 0; i < Math.Min(4, publicPhotos.Count); i++)
                                {
                                    var idx = i;
                                    var photo = publicPhotos[idx];
                                    <div role="button" tabindex="0" style="cursor: pointer; position: relative;"
                                         @onclick="() => OpenGallery(dance, publicPhotos, idx)">
                                        <MudImage Src="@(photo.HasDbData ? $"/api/files/{photo.Id}/image?size=thumb" : photo.Path)"
                                                  Alt="@dance.Name"
                                                  ObjectFit="ObjectFit.Cover"
                                                  Style="border-radius: 4px; height: 80px; width: 100%; display: block;" />
                                        @if (idx == 3 && publicPhotos.Count > 4)
                                        {
                                            <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.55);
                                                        display: flex; align-items: center; justify-content: center;
                                                        color: white; font-weight: 600; border-radius: 4px;">
                                                +@(publicPhotos.Count - 4)
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {

    [Inject] private IDanceService DanceService { get; set; } = null!;

    private List<DanceViewModel> VisibleDances { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        PageService.SetTitle(Localizer[nameof(DemizonLocales.Dances)]);
        var dances = await DanceService.GetAll()
            .Where(x => x.IsVisible)
            .Include(x => x.Videos)
            .Include(x => x.Files)
            .OrderBy(x => x.Name)
            .ToListAsync();
        VisibleDances = dances.Select(x => x.ToViewModel()).ToList();
    }

    private async Task OpenGallery(DanceViewModel dance, List<FileViewModel> photos, int startIndex)
    {
        var parameters = new DialogParameters
        {
            { "PhotoIds", photos.Select(p => p.Id).ToList() },
            { "StartIndex", startIndex },
            { "DanceName", dance.Name }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseOnEscapeKey = true,
            BackdropClick = true
        };
        await DialogService.ShowAsync<DanceGalleryDialog>(dance.Name, parameters, options);
    }

}
