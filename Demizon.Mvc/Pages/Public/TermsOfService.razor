@page "/Terms-of-Service"

@if (_isCzech)
{
    <PageTitle>Podmínky užívání – FS Demižón</PageTitle>

    <MudText Typo="Typo.h4" Class="mb-1">Podmínky užívání</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">Naposledy aktualizováno: 28. dubna 2026</MudText>

    <MudStack Spacing="4">
        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">1. Provozovatel</MudText>
            <MudText Typo="Typo.body1">
                Tuto aplikaci provozuje folklorní soubor <strong>FS Demižón Strážnice</strong>,
                se sídlem Orelská jednota Strážnice, 696 62 Strážnice.
                Kontakt: <MudLink Href="mailto:fs.demizon@gmail.com" Color="Color.Primary">fs.demizon@gmail.com</MudLink>.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">2. Přístup k aplikaci</MudText>
            <MudText Typo="Typo.body1">
                Aplikace je určena výhradně pro aktivní členy folklorního souboru FS Demižón Strážnice.
                Přístup je podmíněn registrací a přidělením přihlašovacích údajů administrátorem souboru.
                Přihlašovací údaje jsou nepřenosné a nesmí být sdíleny s třetími osobami.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">3. Povolené použití</MudText>
            <MudText Typo="Typo.body1" Class="mb-2">Aplikaci je povoleno používat pouze pro:</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">správu vlastní docházky na zkoušky a akce</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">prohlížení plánovaných akcí a harmonogramu zkoušek</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">správu vlastního profilu a nastavení notifikací</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">propojení s Google Calendar pro osobní potřebu</MudListItem>
            </MudList>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">4. Zakázané chování</MudText>
            <MudText Typo="Typo.body1" Class="mb-2">Uživatelé nesmí:</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">pokoušet se o neoprávněný přístup k datům ostatních členů</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">sdílet přihlašovací údaje s třetími osobami</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">používat aplikaci způsobem, který by narušoval její provoz</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">získávat nebo exportovat data ostatních členů bez souhlasu administrátora</MudListItem>
            </MudList>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">5. Integrace třetích stran</MudText>
            <MudText Typo="Typo.body1">
                Aplikace nabízí volitelné propojení se službami třetích stran (Google Calendar, push notifikace).
                Použití těchto integrací je dobrovolné a řídí se podmínkami příslušného poskytovatele.
                Propojení lze kdykoli zrušit v nastavení profilu.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">6. Dostupnost služby</MudText>
            <MudText Typo="Typo.body1">
                Aplikace je provozována jako interní nástroj souboru a není garantována žádná úroveň dostupnosti.
                Provozovatel si vyhrazuje právo kdykoli provádět údržbu, aktualizace nebo změny bez předchozího upozornění.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">7. Ukončení přístupu</MudText>
            <MudText Typo="Typo.body1">
                Přístup k aplikaci může být ukončen administrátorem v případě ukončení členství v souboru nebo
                porušení těchto podmínek. Po ukončení přístupu budou osobní údaje na žádost anonymizovány nebo smazány.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">8. Ochrana osobních údajů</MudText>
            <MudText Typo="Typo.body1">
                Zpracování osobních údajů se řídí našimi
                <MudLink Href="/Privacy-Policy" Color="Color.Primary">Zásadami ochrany osobních údajů</MudLink>,
                které jsou nedílnou součástí těchto podmínek.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">9. Změny podmínek</MudText>
            <MudText Typo="Typo.body1">
                Provozovatel si vyhrazuje právo tyto podmínky kdykoli změnit. O podstatných změnách budou členové
                informováni prostřednictvím aplikace. Pokračování v používání aplikace po oznámení změn představuje
                souhlas s novými podmínkami.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">10. Rozhodné právo</MudText>
            <MudText Typo="Typo.body1">
                Tyto podmínky se řídí právním řádem České republiky. Veškeré spory budou řešeny u příslušných
                českých soudů.
            </MudText>
        </MudCardContent></MudCard>
    </MudStack>
}
else
{
    <PageTitle>Terms of Service – FS Demižón</PageTitle>

    <MudText Typo="Typo.h4" Class="mb-1">Terms of Service</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">Last updated: April 28, 2026</MudText>

    <MudStack Spacing="4">
        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">1. Operator</MudText>
            <MudText Typo="Typo.body1">
                This application is operated by folk ensemble <strong>FS Demižón Strážnice</strong>,
                based at Orelská jednota Strážnice, 696 62 Strážnice, Czech Republic.
                Contact: <MudLink Href="mailto:fs.demizon@gmail.com" Color="Color.Primary">fs.demizon@gmail.com</MudLink>.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">2. Access</MudText>
            <MudText Typo="Typo.body1">
                This application is intended exclusively for active members of FS Demižón Strážnice.
                Access requires registration and login credentials issued by an ensemble administrator.
                Credentials are non-transferable and must not be shared with third parties.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">3. Permitted Use</MudText>
            <MudText Typo="Typo.body1" Class="mb-2">The application may be used only for:</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">managing your own attendance at rehearsals and events</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">viewing upcoming events and the rehearsal schedule</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">managing your own profile and notification settings</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">connecting Google Calendar for personal use</MudListItem>
            </MudList>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">4. Prohibited Conduct</MudText>
            <MudText Typo="Typo.body1" Class="mb-2">Users must not:</MudText>
            <MudList T="string" Dense="true">
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">attempt to access other members' data without authorisation</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">share login credentials with third parties</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">use the application in a way that disrupts its operation</MudListItem>
                <MudListItem Icon="@Icons.Material.Filled.ChevronRight">export or harvest other members' data without administrator consent</MudListItem>
            </MudList>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">5. Third-Party Integrations</MudText>
            <MudText Typo="Typo.body1">
                The application offers optional integrations with third-party services (Google Calendar, push notifications).
                Use of these integrations is voluntary and subject to the respective provider's terms.
                Integrations can be disconnected at any time in your profile settings.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">6. Service Availability</MudText>
            <MudText Typo="Typo.body1">
                The application is operated as an internal ensemble tool and no uptime guarantee is provided.
                The operator reserves the right to perform maintenance, updates or changes at any time without prior notice.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">7. Termination of Access</MudText>
            <MudText Typo="Typo.body1">
                Access may be revoked by an administrator upon leaving the ensemble or in the event of a breach of these
                terms. Upon termination, personal data will be anonymised or deleted upon request.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">8. Privacy</MudText>
            <MudText Typo="Typo.body1">
                The handling of personal data is governed by our
                <MudLink Href="/Privacy-Policy" Color="Color.Primary">Privacy Policy</MudLink>,
                which forms an integral part of these Terms of Service.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">9. Changes to These Terms</MudText>
            <MudText Typo="Typo.body1">
                The operator reserves the right to update these terms at any time. Members will be informed of material
                changes through the application. Continued use of the application after notification of changes constitutes
                acceptance of the new terms.
            </MudText>
        </MudCardContent></MudCard>

        <MudCard Elevation="1"><MudCardContent>
            <MudText Typo="Typo.h6" Class="mb-2">10. Governing Law</MudText>
            <MudText Typo="Typo.body1">
                These terms are governed by the laws of the Czech Republic. Any disputes shall be resolved by the
                competent Czech courts.
            </MudText>
        </MudCardContent></MudCard>
    </MudStack>
}

@code {
    private bool _isCzech;

    protected override void OnInitialized()
    {
        _isCzech = Thread.CurrentThread.CurrentUICulture.Name == "cs-CZ";
    }
}
