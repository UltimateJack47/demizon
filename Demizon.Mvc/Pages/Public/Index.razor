@page "/"

<div class="demi-hero">
    <MudStack Spacing="2" AlignItems="AlignItems.Center" Class="demi-hero-content">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Justify="Justify.Center">
            <MudImage Src="images/logo.jpg" Width="100" Height="100" ObjectFit="ObjectFit.Contain" Style="border-radius: 50%; background: white; padding: 6px; margin-right: 6px;"/>
            <MudStack Spacing="0" AlignItems="AlignItems.Start">
                <MudText Typo="Typo.h2" Class="demi-hero-title">FS Demižón</MudText>
                <MudText Typo="Typo.h5" Class="demi-hero-subtitle">@Localizer[nameof(DemizonLocales.HeroSubtitle)]</MudText>
            </MudStack>
        </MudStack>
        <MudStack Row="true" Spacing="2" Class="mt-2" Justify="Justify.Center">
            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large"
                       Href="@(NavigationManager.BaseUri + "Events")"
                       StartIcon="@Icons.Material.Filled.CalendarMonth">
                @Localizer[nameof(DemizonLocales.EventSchedule)]
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Inherit" Size="Size.Large"
                       Href="@(NavigationManager.BaseUri + "Dances")"
                       StartIcon="@Icons.Material.Filled.AccessibilityNew"
                       Style="color: white; border-color: white;">
                @Localizer[nameof(DemizonLocales.Repertoire)]
            </MudButton>
        </MudStack>
    </MudStack>
</div>

<MudGrid Class="mt-6" Spacing="4">
    <MudItem xs="12" md="6">
        <MudCard Elevation="2" Class="demi-info-card">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Size="Size.Large"/>
                    <MudText Typo="Typo.h5">@Localizer[nameof(DemizonLocales.AboutUs)]</MudText>
                </MudStack>
                <MudText Typo="Typo.body1" Class="mb-2">
                    @Localizer[nameof(DemizonLocales.AboutUsText1)]
                </MudText>
                <MudText Typo="Typo.body1">
                    @Localizer[nameof(DemizonLocales.AboutUsText2)]
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="6">
        <MudCard Elevation="2" Class="demi-info-card">
            <MudCardContent>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.WineBar" Color="Color.Primary" Size="Size.Large"/>
                    <MudText Typo="Typo.h5">@Localizer[nameof(DemizonLocales.WhyDemizon)]</MudText>
                </MudStack>
                <MudText Typo="Typo.body1" Class="mb-2">
                    @Localizer[nameof(DemizonLocales.WhyDemizonText1)]
                </MudText>
                <MudText Typo="Typo.body1" Class="mb-2">
                    @Localizer[nameof(DemizonLocales.WhyDemizonText2)]
                </MudText>
                <MudText Typo="Typo.body1">
                    @Localizer[nameof(DemizonLocales.WhyDemizonText3)]
                </MudText>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudDivider Class="my-6"/>

<MudStack AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudText Typo="Typo.h5">@Localizer[nameof(DemizonLocales.JoinUsCta)]</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large"
               Href="@(NavigationManager.BaseUri + "Join-Us")"
               StartIcon="@Icons.Material.Filled.PersonAdd">
        @Localizer[nameof(DemizonLocales.JoinUs)]
    </MudButton>
</MudStack>

@code {
    protected override void OnInitialized()
    {
        PageService.SetTitle(null);
    }
}
