@page "/Photos"
@using Demizon.Core.Services.File
@using Demizon.Mvc.ViewModels
@using Microsoft.EntityFrameworkCore

<PageTitle>@PageService.GetTitle()</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">@Localizer[nameof(DemizonLocales.Photos)]</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@Localizer[nameof(DemizonLocales.PhotosSubtitle)]</MudText>

@if (GalleryItems.Count == 0)
{
    <MudStack AlignItems="AlignItems.Center" Class="py-8">
        <MudIcon Icon="@Icons.Material.Filled.PhotoAlbum" Style="font-size: 4rem; opacity: 0.3;"/>
        <MudText Typo="Typo.body1" Color="Color.Secondary">@Localizer[nameof(DemizonLocales.PhotosEmpty)]</MudText>
    </MudStack>
}
else
{
    <div class="demi-gallery-grid">
        @for (int i = 0; i < GalleryItems.Count; i++)
        {
            var index = i;
            <div class="demi-gallery-item" @onclick="() => OpenLightbox(index)">
                <img src="@GetThumbnailUrl(GalleryItems[index])" alt="Foto @(index + 1)" loading="lazy"/>
                <div class="demi-gallery-overlay">
                    <MudIcon Icon="@Icons.Material.Filled.ZoomIn" Style="color: white; font-size: 2rem;"/>
                </div>
            </div>
        }
    </div>
}

@code {
    [Inject] private IFileService FileService { get; set; } = null!;
    [Inject] private IJSRuntime Js { get; set; } = null!;

    private List<FileViewModel> GalleryItems { get; set; } = [];
    private bool _initialized;

    protected override async Task OnInitializedAsync()
    {
        PageService.SetTitle(Localizer[nameof(DemizonLocales.Photos)]);
        GalleryItems = await FileService.GetAll()
            .Where(x => x.IsPublic)
            .Where(x => x.ContentType.StartsWith("image/"))
            .OrderByDescending(x => x.Id)
            .Select(x => new FileViewModel
            {
                Id = x.Id,
                Path = x.Path,
                ContentType = x.ContentType,
                FileSize = x.FileSize,
                IsPublic = x.IsPublic,
                HasDbData = x.Data != null,
            })
            .ToListAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (GalleryItems.Count > 0 && !_initialized)
        {
            _initialized = true;
            var items = GalleryItems.Select((g, i) => new
            {
                href = GetFullUrl(g),
                alt = $"Foto {i + 1}"
            }).ToArray();
            await Js.InvokeVoidAsync("demizonGallery.init", (object)items);
        }
    }

    private async Task OpenLightbox(int index)
    {
        await Js.InvokeVoidAsync("demizonGallery.open", index);
    }

    private static string GetThumbnailUrl(FileViewModel file)
    {
        return file.HasDbData ? $"/api/files/{file.Id}/image?size=thumb" : file.Path;
    }

    private static string GetFullUrl(FileViewModel file)
    {
        return file.HasDbData ? $"/api/files/{file.Id}/image?size=full" : file.Path;
    }
}
