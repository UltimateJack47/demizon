<MudPaper Elevation="0">
    <MudNavMenu>
        <MudNavLink Href="@(NavigationManager.BaseUri)" Match="NavLinkMatch.All"
                    Icon="@Icons.Material.Filled.Home">
            @Localizer[nameof(DemizonLocales.PublicHome)]
        </MudNavLink>
        <MudNavLink Href="@(NavigationManager.BaseUri + "Admin/Dances")"
                    Icon="@Icons.Material.Filled.Celebration">
            @Localizer[nameof(DemizonLocales.Dances)]
        </MudNavLink>
        <MudNavLink Href="@(NavigationManager.BaseUri + "Admin/Events")"
                    Icon="@Icons.Material.Filled.Event">
            @Localizer[nameof(DemizonLocales.Events)]
        </MudNavLink>
        <MudNavLink Href="@(NavigationManager.BaseUri + "Admin/Members")"
                    Icon="@Icons.Material.Filled.People">
            @Localizer[nameof(DemizonLocales.Members)]
        </MudNavLink>
        <MudNavLink Href="@(NavigationManager.BaseUri + "Admin/MemberAttendance")"
                    Icon="@Icons.Material.Filled.CalendarMonth">
            @Localizer[nameof(DemizonLocales.Attendance)]
        </MudNavLink>
        <AuthorizeView Roles="Admin">
            <MudNavLink Href="@(NavigationManager.BaseUri + "Admin/Videos")"
                        Icon="@Icons.Material.Filled.VideoLibrary">
                @Localizer[nameof(DemizonLocales.Videos)]
            </MudNavLink>
        </AuthorizeView>
        <MudNavLink Href="@(NavigationManager.BaseUri + "Admin/Profile")"
                    Icon="@Icons.Material.Filled.AccountCircle">
            @Localizer[nameof(DemizonLocales.Profile)]
        </MudNavLink>
    </MudNavMenu>
</MudPaper>
