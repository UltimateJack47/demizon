@inherits LayoutComponentBase

<PageTitle>@PageService.GetTitle()</PageTitle>

<MudLayout>
    <MudAppBar Elevation="2" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit"
                       Edge="Edge.Start" OnClick="@(_ => DrawerToggle())"/>
        <MudText Typo="Typo.h6" Class="ml-2 d-none d-sm-flex" Style="font-family: Georgia, serif; letter-spacing: 0.05em;">
            FS Demižón
        </MudText>
        <MudSpacer/>
        <MudIconButton Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Size="Size.Small"
                       title="Jazyk / Language"/>
        <MudButton Size="Size.Small" Color="Color.Inherit" OnClick="@(() => SetCulture("cs"))">CS</MudButton>
        <MudText Color="Color.Inherit" Style="opacity:0.5">/</MudText>
        <MudButton Size="Size.Small" Color="Color.Inherit" OnClick="@(() => SetCulture("en"))">EN</MudButton>
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.AdminPanelSettings" Color="Color.Inherit"
                               Href="@(NavigationManager.BaseUri + "Admin/Dances")" title="Administrace"/>
                <MudIconButton Href="@(NavigationManager.BaseUri + "Logout")" Color="Color.Inherit"
                               Icon="@Icons.Material.Filled.Logout" title="Odhlásit"/>
            </Authorized>
            <NotAuthorized>
                <MudIconButton Icon="@Icons.Material.Filled.Login" Color="Color.Inherit"
                               Href="@(NavigationManager.BaseUri + "Login")" title="Přihlásit"/>
            </NotAuthorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="DrawerOpen" Elevation="2" Variant="DrawerVariant.Temporary" ClipMode="DrawerClipMode.Always">
        <MudDrawerHeader Class="pa-4" Style="background: linear-gradient(135deg, #9B1A1A 0%, #C84B4B 100%);">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudImage Src="@(NavigationManager.BaseUri + "favicon.gif")" Width="36" Height="36" ObjectFit="ObjectFit.Contain"/>
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6" Style="color: white; font-family: Georgia, serif; line-height: 1.2;">FS Demižón</MudText>
                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.75);">Strážnice</MudText>
                </MudStack>
            </MudStack>
        </MudDrawerHeader>
        <NavMenu></NavMenu>
        <MudSpacer/>
        <MudDivider/>
        <MudText Typo="Typo.caption" Class="pa-3" Style="color: var(--mud-palette-text-secondary);">
            © @DateTime.Now.Year FS Demižón Strážnice
        </MudText>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="pa-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    bool DrawerOpen = false;

    void DrawerToggle()
    {
        DrawerOpen = !DrawerOpen;
    }

    private void SetCulture(string culture)
    {
        NavigationManager.NavigateTo(NavigationManager.BaseUri + $"SetLanguage/{culture}", true);
    }
}
