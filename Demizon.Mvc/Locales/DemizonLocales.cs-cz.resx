    <data name="JoinUsText1" xml:space="preserve">
        <value>Pokud se chcete naučit tancovat – ať už vy sami, nebo znáte někoho takového – stačí nás oslovit nebo rovnou v pátek přijít na nácvik!</value>
    </data>
    <data name="JoinUsText2" xml:space="preserve">
