<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)"/>
            <FocusOnNavigate RouteData="@routeData" Selector="h1"/>
        </Found>
        <NotFound>
            <PageTitle>Not found</PageTitle>
            <LayoutView Layout="@typeof(MainLayout)">
                <p role="alert">Sorry, there's nothing at this address.</p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>

<MudThemeProvider Theme="MyCustomTheme"/>
<MudDialogProvider/>
<MudSnackbarProvider/>

@code{

    MudTheme MyCustomTheme = new MudTheme
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#9B1A1A",
            PrimaryDarken = "#6B0000",
            PrimaryLighten = "#C84B4B",
            Secondary = "#C8912A",
            SecondaryDarken = "#966A0E",
            AppbarBackground = "#9B1A1A",
            Background = "#FAFAF7",
            Surface = "#FFFFFF",
            DrawerBackground = "#FDFCF8",
            DrawerText = "#3A2A1A",
            TextPrimary = "#2C1A0A",
            TextSecondary = "#6B4C2A",
            ActionDefault = "#9B1A1A",
        },
        LayoutProperties = new LayoutProperties
        {
            DrawerWidthLeft = "240px",
        },
        Typography = new Typography
        {
            Default = new DefaultTypography { FontFamily = ["Georgia", "serif"] },
            H1 = new H1Typography { FontFamily = ["Georgia", "serif"], FontWeight = "700" },
            H2 = new H2Typography { FontFamily = ["Georgia", "serif"], FontWeight = "700" },
            H3 = new H3Typography { FontFamily = ["Georgia", "serif"], FontWeight = "600" },
            H4 = new H4Typography { FontFamily = ["Georgia", "serif"], FontWeight = "600" },
            H5 = new H5Typography { FontFamily = ["Georgia", "serif"], FontWeight = "600" },
        }
    };

}
