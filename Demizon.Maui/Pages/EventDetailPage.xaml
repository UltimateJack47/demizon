<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demizon.Maui.ViewModels"
             xmlns:events="clr-namespace:Demizon.Contracts.Events;assembly=Demizon.Contracts"
             x:Class="Demizon.Maui.Pages.EventDetailPage"
             x:DataType="vm:EventDetailViewModel"
             Title="{Binding Event.Name}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Hero card -->
            <Border Style="{StaticResource CardBorder}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding Event.Name}"
                           Style="{StaticResource TitleLabel}" />

                    <HorizontalStackLayout Spacing="8">
                        <Label Text="📅" FontSize="16" VerticalOptions="Center" />
                        <Label Text="{Binding Event.DateFrom, Converter={StaticResource DateFormatConverter}}"
                               Style="{StaticResource SubtitleLabel}" VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="8"
                                           IsVisible="{Binding Event.Place, Converter={StaticResource StringToBoolConverter}}">
                        <Label Text="📍" FontSize="16" VerticalOptions="Center" />
                        <Label Text="{Binding Event.Place}"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Cancelled badge -->
                    <Border BackgroundColor="{StaticResource AttendanceRed}"
                            StrokeShape="RoundRectangle 6"
                            Stroke="Transparent"
                            Padding="10,4"
                            HorizontalOptions="Start"
                            IsVisible="{Binding Event.IsCancelled}">
                        <Label Text="ZRUŠENO"
                               TextColor="White"
                               FontAttributes="Bold"
                               FontSize="13" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Attendees section — "Kdo přijde" -->
            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding ShowAttendees}"
                    Padding="16">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Kdo přijde"
                           FontAttributes="Bold"
                           FontSize="18" />

                    <!-- Summary counts -->
                    <FlexLayout Wrap="Wrap" AlignItems="Center" JustifyContent="Start">
                        <HorizontalStackLayout Spacing="4" Margin="0,0,16,4">
                            <Label Text="👥" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding Attendees.TotalCount, StringFormat='Celkem: {0}'}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4" Margin="0,0,16,4">
                            <Label Text="💃" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding Attendees.DancerCount, StringFormat='Tanečníci: {0}'}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="4" Margin="0,0,0,4">
                            <Label Text="🎵" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding Attendees.MusicianCount, StringFormat='Muzikanti: {0}'}"
                                   FontSize="13"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </FlexLayout>

                    <!-- Attendee list -->
                    <StackLayout BindableLayout.ItemsSource="{Binding Attendees.Attendees}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="events:EventAttendeeDto">
                                <HorizontalStackLayout Spacing="8" Padding="0,4">
                                    <Label Text="✓"
                                           TextColor="{StaticResource AttendanceGreen}"
                                           FontAttributes="Bold"
                                           FontSize="14"
                                           VerticalOptions="Center" />
                                    <Label Text="{Binding FullName}"
                                           FontSize="14"
                                           VerticalOptions="Center" />
                                    <Label Text="{Binding ActivityRole}"
                                           TextColor="{StaticResource TextSecondary}"
                                           FontSize="12"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </StackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Attendance section -->
            <Label Text="Moje docházka"
                   FontAttributes="Bold"
                   FontSize="18"
                   Margin="0,8,0,0" />

            <!-- Toggle buttons -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                <!-- Přijdu button: filled green when Status="yes" -->
                <Button x:Name="BtnAttend"
                        Grid.Column="0"
                        Text="✓ Přijdu"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter="yes"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource AttendanceGreen}"
                        BorderColor="{StaticResource AttendanceGreen}"
                        BorderWidth="2"
                        CornerRadius="12"
                        FontSize="14"
                        FontAttributes="Bold"
                        HeightRequest="52">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding Status}" Value="yes">
                            <Setter Property="BackgroundColor" Value="{StaticResource AttendanceGreen}" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <!-- Nevím button: filled yellow when Status="maybe" -->
                <Button x:Name="BtnMaybe"
                        Grid.Column="1"
                        Text="? Nevím"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter="maybe"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource AttendanceYellow}"
                        BorderColor="{StaticResource AttendanceYellow}"
                        BorderWidth="2"
                        CornerRadius="12"
                        FontSize="14"
                        FontAttributes="Bold"
                        HeightRequest="52">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding Status}" Value="maybe">
                            <Setter Property="BackgroundColor" Value="{StaticResource AttendanceYellow}" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <!-- Nepřijdu button: filled red when Status="no" -->
                <Button x:Name="BtnDecline"
                        Grid.Column="2"
                        Text="✗ Nepřijdu"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter="no"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource AttendanceRed}"
                        BorderColor="{StaticResource AttendanceRed}"
                        BorderWidth="2"
                        CornerRadius="12"
                        FontSize="14"
                        FontAttributes="Bold"
                        HeightRequest="52">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button" Binding="{Binding Status}" Value="no">
                            <Setter Property="BackgroundColor" Value="{StaticResource AttendanceRed}" />
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <!-- Reset button -->
                <Button Grid.Column="3"
                        Text="↺"
                        Command="{Binding SetStatusCommand}"
                        CommandParameter=""
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        BorderColor="{StaticResource TextSecondary}"
                        BorderWidth="2"
                        CornerRadius="12"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="52"
                        ToolTipProperties.Text="Reset" />
            </Grid>

            <!-- Role picker - visible only when attending -->
            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding IsAttending}"
                    Padding="12">
                <Picker Title="Vyberte roli"
                        ItemsSource="{Binding RoleOptions}"
                        SelectedItem="{Binding ActivityRole}" />
            </Border>

            <!-- Comment -->
            <Border Style="{StaticResource CardBorder}" Padding="12">
                <Editor Placeholder="Poznámka..."
                        Text="{Binding Comment}"
                        HeightRequest="100"
                        AutoSize="TextChanges" />
            </Border>

            <!-- Save button -->
            <Button Text="Uložit docházku"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveAttendanceCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="0,8,0,0" />

            <!-- Admin section -->
            <Border Style="{StaticResource CardBorder}"
                    IsVisible="{Binding IsAdmin}"
                    Padding="16"
                    Margin="0,8,0,0">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Správa akce"
                           FontAttributes="Bold"
                           FontSize="18"
                           TextColor="#3E2723" />

                    <Button Text="✏️ Upravit akci"
                            Command="{Binding EditEventCommand}"
                            BackgroundColor="#A8845E"
                            TextColor="White"
                            CornerRadius="12"
                            FontAttributes="Bold" />

                    <Button Text="🗑️ Smazat akci"
                            Command="{Binding DeleteEventCommand}"
                            BackgroundColor="Transparent"
                            TextColor="#C0392B"
                            BorderColor="#C0392B"
                            BorderWidth="1"
                            CornerRadius="12"
                            FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
