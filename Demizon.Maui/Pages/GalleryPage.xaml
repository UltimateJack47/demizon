<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demizon.Maui.ViewModels"
             x:Class="Demizon.Maui.Pages.GalleryPage"
             x:DataType="vm:GalleryViewModel"
             Title="Fotogalerie">

    <Grid>
        <!-- Loading indicator -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <!-- Empty state -->
        <VerticalStackLayout IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8"
                             Padding="20">
            <Label Text="📷" FontSize="48" HorizontalOptions="Center" />
            <Label Text="Žádné fotografie"
                   Style="{StaticResource TitleLabel}"
                   HorizontalOptions="Center" />
            <Label Text="Zatím nebyly přidány žádné veřejné fotografie."
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Photo grid -->
        <CollectionView ItemsSource="{Binding Photos}"
                        IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        SelectionMode="None">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical"
                                 Span="3"
                                 HorizontalItemSpacing="4"
                                 VerticalItemSpacing="4" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:GalleryPhotoItem">
                    <Border StrokeShape="RoundRectangle 4"
                            Stroke="Transparent"
                            HeightRequest="120">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:GalleryViewModel}}, Path=OpenPhotoCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Image Source="{Binding ThumbnailUrl}"
                               Aspect="AspectFill" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
