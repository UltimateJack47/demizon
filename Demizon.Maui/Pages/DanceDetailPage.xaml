<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demizon.Maui.ViewModels"
             xmlns:dto="clr-namespace:Demizon.Contracts.Dances;assembly=Demizon.Contracts"
             x:Class="Demizon.Maui.Pages.DanceDetailPage"
             x:DataType="vm:DanceDetailViewModel"
             Title="{Binding Dance.Name}"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Hero section -->
            <VerticalStackLayout Spacing="8">
                <Label Text="{Binding Dance.Name}"
                       Style="{StaticResource TitleLabel}" />
                <Border BackgroundColor="{StaticResource PrimaryDark}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,6"
                        HorizontalOptions="Start"
                        IsVisible="{Binding Dance.Region, Converter={StaticResource StringToBoolConverter}}">
                    <Label Text="{Binding Dance.Region}"
                           TextColor="White"
                           FontSize="13" />
                </Border>
            </VerticalStackLayout>

            <!-- Description section -->
            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding Dance.Description, Converter={StaticResource StringToBoolConverter}}">
                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                <Label Text="{Binding Dance.Description}"
                       Style="{StaticResource BodyLabel}"
                       LineHeight="1.4" />
            </VerticalStackLayout>

            <!-- Lyrics section (expandable) -->
            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding Dance.Lyrics, Converter={StaticResource StringToBoolConverter}}">
                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0"
                           Text="Text písně"
                           Style="{StaticResource SubtitleLabel}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="{Binding IsLyricsExpanded, StringFormat='{}{0:IsLyricsExpanded}'}"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleLyricsCommand}"
                            WidthRequest="100"
                            HeightRequest="36"
                            FontSize="13">
                        <Button.Triggers>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsLyricsExpanded}"
                                         Value="True">
                                <Setter Property="Text" Value="Skrýt" />
                            </DataTrigger>
                            <DataTrigger TargetType="Button"
                                         Binding="{Binding IsLyricsExpanded}"
                                         Value="False">
                                <Setter Property="Text" Value="Zobrazit" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </Grid>
                <Label Text="{Binding Dance.Lyrics}"
                       Style="{StaticResource BodyLabel}"
                       LineHeight="1.5"
                       IsVisible="{Binding IsLyricsExpanded}" />
            </VerticalStackLayout>

            <!-- Videos section -->
            <VerticalStackLayout Spacing="10">
                <BoxView HeightRequest="1" Color="{StaticResource Gray200}" />
                <Label Text="Videa"
                       Style="{StaticResource SubtitleLabel}" />

                <CollectionView ItemsSource="{Binding Dance.Videos}">
                    <CollectionView.EmptyView>
                        <Label Text="Žádná videa"
                               Style="{StaticResource CaptionLabel}"
                               HorizontalOptions="Center"
                               Margin="0,12" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="dto:VideoLinkDto">
                            <Border Style="{StaticResource CardBorder}"
                                    Margin="0,4">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DanceDetailViewModel}}, Path=OpenVideoCommand}"
                                                          CommandParameter="{Binding Url}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="▶"
                                           FontSize="20"
                                           TextColor="{StaticResource Primary}"
                                           VerticalOptions="Center" />
                                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                               FontAttributes="Bold"
                                               FontSize="15"
                                               TextColor="{StaticResource TextPrimary}" />
                                        <Border BackgroundColor="{StaticResource WarmBeige}"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 8"
                                                Padding="8,3"
                                                HorizontalOptions="Start">
                                            <Label Text="{Binding Year}"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TextSecondary}" />
                                        </Border>
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
