<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demizon.Maui.ViewModels"
             x:Class="Demizon.Maui.Pages.ChangePasswordPage"
             x:DataType="vm:ChangePasswordViewModel"
             Title="Změna hesla"
             BackgroundColor="{StaticResource PageBackground}">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Current password -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Aktuální heslo" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Entry Placeholder="Zadejte aktuální heslo"
                           Text="{Binding CurrentPassword}"
                           IsPassword="True" />
                </Border>
            </VerticalStackLayout>

            <!-- New password -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Nové heslo" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Entry Placeholder="Zadejte nové heslo"
                           Text="{Binding NewPassword}"
                           IsPassword="True" />
                </Border>
            </VerticalStackLayout>

            <!-- Confirm password -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Potvrzení nového hesla" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Entry Placeholder="Zadejte nové heslo znovu"
                           Text="{Binding ConfirmPassword}"
                           IsPassword="True" />
                </Border>
            </VerticalStackLayout>

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorColor}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                   FontSize="14" />

            <!-- Success message -->
            <Label Text="{Binding SuccessMessage}"
                   TextColor="{StaticResource AttendanceGreen}"
                   IsVisible="{Binding SuccessMessage, Converter={StaticResource StringToBoolConverter}}"
                   FontSize="14" />

            <!-- Save button -->
            <Button Text="Změnit heslo"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding ChangeCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="0,8,0,20" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
