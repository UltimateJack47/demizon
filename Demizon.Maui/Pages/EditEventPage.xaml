<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demizon.Maui.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             x:Class="Demizon.Maui.Pages.EditEventPage"
             x:DataType="vm:EditEventViewModel"
             Title="Upravit akci">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <!-- Name -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Název akce" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Entry Placeholder="Např. Zkoušky, Vystoupení..."
                           Text="{Binding Name}" />
                </Border>
            </VerticalStackLayout>

            <!-- Date From -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Začátek" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="12,8">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding DateFromDate}"
                                    Format="dd.MM.yyyy" />
                        <TimePicker Grid.Column="1"
                                    Time="{Binding DateFromTime}"
                                    Format="HH:mm" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Date To -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Konec" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="12,8">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <DatePicker Grid.Column="0"
                                    Date="{Binding DateToDate}"
                                    Format="dd.MM.yyyy"
                                    MinimumDate="{Binding DateFromDate}" />
                        <TimePicker Grid.Column="1"
                                    Time="{Binding DateToTime}"
                                    Format="HH:mm" />
                    </Grid>
                </Border>
            </VerticalStackLayout>

            <!-- Place -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Místo (volitelné)" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Entry Placeholder="Např. Sokolovna, Sál..."
                           Text="{Binding Place}" />
                </Border>
            </VerticalStackLayout>

            <!-- NotifyBeforeDays -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Upozornění předem" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Picker Title="Vyberte..."
                            ItemsSource="{Binding NotifyOptions}"
                            SelectedIndex="{Binding NotifyBeforeDaysIndex}" />
                </Border>
            </VerticalStackLayout>

            <!-- Recurrence -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Opakování" Style="{StaticResource CaptionLabel}" />
                <Border Style="{StaticResource CardBorder}" Padding="8,4">
                    <Picker Title="Vyberte..."
                            ItemsSource="{Binding RecurrenceOptions}"
                            SelectedIndex="{Binding RecurrenceIndex}" />
                </Border>
            </VerticalStackLayout>

            <!-- IsPublic toggle -->
            <Border Style="{StaticResource CardBorder}" Padding="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Veřejná akce"
                           VerticalOptions="Center"
                           TextColor="{StaticResource TextSecondary}" />
                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsPublic}"
                            OnColor="#A8845E"
                            ThumbColor="#9A7450" />
                </Grid>
            </Border>

            <!-- IsCancelled toggle -->
            <Border Style="{StaticResource CardBorder}" Padding="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="Zrušená akce"
                           VerticalOptions="Center"
                           TextColor="{StaticResource TextSecondary}" />
                    <Switch Grid.Column="1"
                            IsToggled="{Binding IsCancelled}"
                            OnColor="{StaticResource AttendanceRed}"
                            ThumbColor="#C0392B" />
                </Grid>
            </Border>

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource ErrorColor}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}"
                   FontSize="14" />

            <!-- Save button -->
            <Button Text="Uložit změny"
                    Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="0,8,0,0" />

            <!-- Delete button -->
            <Button Text="Smazat akci"
                    BackgroundColor="Transparent"
                    TextColor="#C0392B"
                    BorderColor="#C0392B"
                    BorderWidth="1"
                    CornerRadius="12"
                    FontAttributes="Bold"
                    Command="{Binding DeleteCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                    Margin="0,0,0,20" />

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
