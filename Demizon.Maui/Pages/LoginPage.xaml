<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Demizon.Maui.ViewModels"
             x:Class="Demizon.Maui.Pages.LoginPage"
             Title="Přihlášení"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Hero gradient section -->
        <BoxView Grid.Row="0"
                 HeightRequest="320">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{StaticResource Primary}" Offset="0.0" />
                    <GradientStop Color="{StaticResource PrimaryDark}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Hero content (logo + titles) -->
        <VerticalStackLayout Grid.Row="0"
                             Spacing="8"
                             Padding="0,56,0,72"
                             HorizontalOptions="Center"
                             VerticalOptions="Center">

            <!-- Logo -->
            <Border StrokeShape="RoundRectangle 50"
                    Stroke="{StaticResource TextOnPrimary}"
                    StrokeThickness="3"
                    BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                    WidthRequest="100"
                    HeightRequest="100"
                    HorizontalOptions="Center">
                <Image Source="demizon_logo.png"
                       WidthRequest="80"
                       HeightRequest="80"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </Border>

            <Label Text="FS Demižón"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextOnPrimary}"
                   HorizontalOptions="Center" />

            <Label Text="Strážnice"
                   FontSize="16"
                   TextColor="{StaticResource TextOnPrimary}"
                   Opacity="0.75"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

        <!-- Login form card -->
        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Margin="24,280,24,0"
                Padding="24,28"
                VerticalOptions="Start"
                StrokeShape="RoundRectangle 12"
                Stroke="Transparent"
                BackgroundColor="{AppThemeBinding Light={StaticResource CardBackground}, Dark={StaticResource CardBackgroundDark}}"
                Shadow="{Shadow Brush=Black, Offset='0,4', Radius=16, Opacity=0.12}">

            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">

                <!-- Login entry -->
                <Entry Grid.Row="0"
                       Placeholder="👤  Přihlašovací jméno"
                       Text="{Binding Login}"
                       AutomationId="LoginEntry"
                       Margin="0,0,0,12" />

                <!-- Password entry -->
                <Entry Grid.Row="1"
                       Placeholder="Heslo"
                       Text="{Binding Password}"
                       IsPassword="True"
                       AutomationId="PasswordEntry"
                       Margin="0,0,0,12" />

                <!-- Error message -->
                <Label Grid.Row="2"
                       Text="{Binding ErrorMessage}"
                       TextColor="Red"
                       FontSize="13"
                       Margin="0,0,0,8"
                       IsVisible="{Binding ErrorMessage, Converter={StaticResource StringToBoolConverter}}" />

                <!-- Login button -->
                <Button Grid.Row="3"
                        Text="Přihlásit se"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        Margin="0,4,0,0"
                        HeightRequest="48" />

                <!-- Loading indicator overlay -->
                <ActivityIndicator Grid.Row="3"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource Primary}"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>
