<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:Demizon.Maui.Pages"
       xmlns:attendance="clr-namespace:Demizon.Maui.Pages.Attendance"
       x:Class="Demizon.Maui.AppShell"
       FlyoutBehavior="Disabled"
       Shell.NavBarIsVisible="False"
       Shell.BackgroundColor="#9A7450"
       Shell.ForegroundColor="White"
       Shell.TitleColor="White"
       Shell.TabBarBackgroundColor="#FAF3E8"
       Shell.TabBarTitleColor="#A8845E"
       Shell.TabBarUnselectedColor="#8A6848"
       Shell.TabBarForegroundColor="#A8845E">

    <!-- Pre-auth route (no navbar, no tab bar) -->
    <ShellContent Route="login"
                  ContentTemplate="{DataTemplate pages:LoginPage}"
                  Shell.NavBarIsVisible="False"
                  Shell.TabBarIsVisible="False" />

    <!-- Post-auth tabs -->
    <TabBar Route="main">
        <ShellContent Title="Docházka"
                      Icon="tab_attendance.svg"
                      Route="attendance"
                      Shell.NavBarIsVisible="False"
                      ContentTemplate="{DataTemplate attendance:AttendancePage}" />
        <ShellContent Title="Akce"
                      Icon="tab_events.svg"
                      Route="events"
                      Shell.NavBarIsVisible="False"
                      ContentTemplate="{DataTemplate pages:EventsPage}" />
        <ShellContent Title="Tance"
                      Icon="tab_dances.svg"
                      Route="dances"
                      Shell.NavBarIsVisible="False"
                      ContentTemplate="{DataTemplate pages:DancesPage}" />
        <ShellContent Title="Profil"
                      Icon="tab_profile.svg"
                      Route="profile"
                      Shell.NavBarIsVisible="False"
                      ContentTemplate="{DataTemplate pages:ProfilePage}" />
    </TabBar>
</Shell>
